<% pageTitle = 'Referrals' %>
<%- include('partials/head') %>
<%- include('partials/nav') %>
<%- include('partials/statsbar') %>
<div class="container">
  <div class="page-header"><h1><i class="fas fa-users"></i> Referral Program</h1><p>Earn <%= commissionRate %>% commission whenever your referrals activate an investment plan.</p></div>
  <div class="stats-grid mb-4">
    <div class="stat-card"><div class="stat-icon cyan"><i class="fas fa-users"></i></div><div class="stat-info"><div class="stat-label">Total Referrals</div><div class="stat-value"><%= refs.length %></div></div></div>
    <div class="stat-card"><div class="stat-icon green"><i class="fas fa-dollar-sign"></i></div><div class="stat-info"><div class="stat-label">Referral Earnings</div><div class="stat-value">$<%= (user.referralEarnings||0).toFixed(4) %></div></div></div>
    <div class="stat-card"><div class="stat-icon gold"><i class="fas fa-percentage"></i></div><div class="stat-info"><div class="stat-label">Commission Rate</div><div class="stat-value"><%= commissionRate %>%</div></div></div>
  </div>
  <div class="referral-box mb-4">
    <h3><i class="fas fa-link" style="color:var(--accent);"></i> Your Referral Link</h3>
    <p>Share and earn <%= commissionRate %>% commission on every plan your referrals activate.</p>
    <div class="copy-box mb-2" data-copy="<%= refLink %>" style="font-size:.85rem;"><%= refLink %><div class="copy-hint"><i class="fas fa-copy"></i> Click to copy</div></div>
    <div style="margin-top:.5rem;"><span style="font-size:.82rem;color:var(--text-muted);">Code: </span><span class="copy-box" data-copy="<%= user.referralCode %>" style="display:inline-block;padding:.3rem .75rem;font-size:.88rem;font-weight:700;"><%= user.referralCode %></span></div>
  </div>
  <div class="card">
    <div class="card-header"><span class="card-title"><i class="fas fa-list"></i> My Referrals (<%= refs.length %>)</span></div>
    <% if (!refs.length) { %><div class="empty-state"><i class="fas fa-user-plus"></i><p>No referrals yet. Share your link!</p></div>
    <% } else { %>
    <div class="table-responsive"><table class="table">
      <thead><tr><th>Username</th><th>Plan</th><th>Joined</th></tr></thead>
      <tbody><% refs.forEach(r => { %><tr><td><i class="fas fa-user" style="color:var(--accent);margin-right:.4rem;"></i><%= r.username %></td><td><span class="badge badge-info"><%= r.planName %></span></td><td style="font-size:.82rem;color:var(--text-muted);"><%= new Date(r.createdAt).toLocaleDateString() %></td></tr><% }) %></tbody>
    </table></div>
    <% } %>
  </div>
</div>
<%- include('partials/footer') %>
