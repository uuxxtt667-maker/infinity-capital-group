<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-brand">
      <div class="logo-txt"><%= siteCustomize.logoText %><span><%= siteCustomize.logoAccent %></span></div>
      <p><%- siteCustomize.footerTagline %></p>
    </div>
    <div class="footer-links">
      <h4>Quick Links</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/#plans">Investment Plans</a></li>
        <li><a href="/register">Create Account</a></li>
        <li><a href="/login">Investor Login</a></li>
      </ul>
    </div>
    <div class="footer-links">
      <h4>Support</h4>
      <ul>
        <li><a href="mailto:<%= siteCustomize.supportEmail %>"><i class="fas fa-envelope"></i> <%= siteCustomize.supportEmail %></a></li>
        <% if(siteCustomize.telegramLink){%><li><a href="<%= siteCustomize.telegramLink %>" target="_blank"><i class="fab fa-telegram"></i> Telegram</a></li><%}%>
        <% if(siteCustomize.whatsappLink){%><li><a href="<%= siteCustomize.whatsappLink %>" target="_blank"><i class="fab fa-whatsapp"></i> WhatsApp</a></li><%}%>
        <% if(siteCustomize.socialTwitter){%><li><a href="<%= siteCustomize.socialTwitter %>" target="_blank"><i class="fab fa-x-twitter"></i> Twitter / X</a></li><%}%>
        <% if(siteCustomize.socialFacebook){%><li><a href="<%= siteCustomize.socialFacebook %>" target="_blank"><i class="fab fa-facebook"></i> Facebook</a></li><%}%>
        <% if(siteCustomize.socialInstagram){%><li><a href="<%= siteCustomize.socialInstagram %>" target="_blank"><i class="fab fa-instagram"></i> Instagram</a></li><%}%>
        <% if(siteCustomize.socialYouTube){%><li><a href="<%= siteCustomize.socialYouTube %>" target="_blank"><i class="fab fa-youtube"></i> YouTube</a></li><%}%>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; <%= new Date().getFullYear() %> <%= siteCustomize.logoText %><%= siteCustomize.logoAccent %>. All rights reserved. &mdash; <strong>DISCLAIMER:</strong> <%- siteCustomize.footerDisclaimer %></p>
  </div>
</footer>
<script src="/js/main.js"></script>
<% if (siteCustomize.floatingBtnsEnabled === 'true' && !path.startsWith('/admin')) { %>
<div id="floatingBtns" style="position:fixed;bottom:1.5rem;<%=siteCustomize.floatingBtnPosition==='left'?'left':'right'%>:1.5rem;z-index:9990;display:flex;flex-direction:column;gap:.6rem;align-items:<%=siteCustomize.floatingBtnPosition==='left'?'flex-start':'flex-end'%>;">
  <% if(siteCustomize.floatingTelegramLink){ %>
  <a href="<%= siteCustomize.floatingTelegramLink %>" target="_blank" rel="noopener" title="Chat on Telegram"
     style="display:flex;align-items:center;justify-content:center;width:52px;height:52px;border-radius:50%;background:#0088cc;color:#fff;font-size:1.4rem;box-shadow:0 4px 18px rgba(0,136,204,.45);text-decoration:none;transition:transform .2s;"
     onmouseover="this.style.transform='scale(1.12)'" onmouseout="this.style.transform='scale(1)'">
    <i class="fab fa-telegram"></i>
  </a>
  <% } %>
  <% if(siteCustomize.floatingWhatsappLink){ %>
  <a href="<%= siteCustomize.floatingWhatsappLink %>" target="_blank" rel="noopener" title="Chat on WhatsApp"
     style="display:flex;align-items:center;justify-content:center;width:52px;height:52px;border-radius:50%;background:#25d366;color:#fff;font-size:1.4rem;box-shadow:0 4px 18px rgba(37,211,102,.45);text-decoration:none;transition:transform .2s;"
     onmouseover="this.style.transform='scale(1.12)'" onmouseout="this.style.transform='scale(1)'">
    <i class="fab fa-whatsapp"></i>
  </a>
  <% } %>
</div>
<% } %>
<% if (siteCustomize.customJs && siteCustomize.customJs.trim()) { %>
<script id="admin-custom-js"><%- siteCustomize.customJs %></script>
<% } %>
