<% pageTitle = 'Admin — Withdrawals' %>
<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="admin-layout">
  <nav class="admin-sidebar">
    <div class="sidebar-title">Admin Panel</div>
    <a href="/admin"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
    <a href="/admin/users"><i class="fas fa-users"></i> Users</a>
    <a href="/admin/plans"><i class="fas fa-layer-group"></i> Plans</a>
    <a href="/admin/plan-requests"><i class="fas fa-tasks"></i> Plan Requests <% if(adminPendingPlanReqs>0){%><span style="background:var(--danger);color:#fff;border-radius:10px;padding:1px 7px;font-size:.68rem;font-weight:700;margin-left:.3rem;"><%= adminPendingPlanReqs %></span><%}%></a>
    <a href="/admin/deposits"><i class="fas fa-plus-circle"></i> Deposits <% if(adminPendingDeposits>0){%><span style="background:var(--danger);color:#fff;border-radius:10px;padding:1px 7px;font-size:.68rem;font-weight:700;margin-left:.3rem;"><%= adminPendingDeposits %></span><%}%></a>
    <a href="/admin/withdrawals" class="active"><i class="fas fa-minus-circle"></i> Withdrawals <% if(adminPendingWithdrawals>0){%><span style="background:var(--danger);color:#fff;border-radius:10px;padding:1px 7px;font-size:.68rem;font-weight:700;margin-left:.3rem;"><%= adminPendingWithdrawals %></span><%}%></a>
    <a href="/admin/transactions"><i class="fas fa-exchange-alt"></i> Transactions</a>
    <div class="sidebar-title">Site</div>
    <a href="/admin/settings"><i class="fas fa-cog"></i> Settings</a>
    <a href="/admin/customize"><i class="fas fa-paint-brush"></i> Customizer</a>
    <a href="/admin/profile"><i class="fas fa-user-shield"></i> Profile &amp; Security</a>
    <a href="/admin/system"><i class="fas fa-server"></i> System Info</a>
    <a href="/dashboard"><i class="fas fa-home"></i> Front End</a>
    <a href="/logout" style="color:var(--danger)"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </nav>
  <div class="admin-main">
    <div class="page-header"><h1><i class="fas fa-minus-circle"></i> Withdrawals</h1></div>
    <div class="tabs mb-3">
      <% [['pending','Pending'],['processing','Processing'],['completed','Completed'],['rejected','Rejected'],['all','All']].forEach(([s,l])=>{%>
      <a href="/admin/withdrawals?status=<%= s %>" class="tab-btn <%= filter===s?'active':'' %>" style="text-decoration:none;"><%= l %></a>
      <%})%>
    </div>
    <div class="card">
      <% if (!wds.length) { %><div class="empty-state"><i class="fas fa-inbox"></i><p>No withdrawals.</p></div>
      <% } else { %>
      <div class="table-responsive"><table class="table">
        <thead><tr><th>User</th><th>Amount</th><th>Network</th><th>Full Wallet Address</th><th>Status</th><th>Date</th><th>Actions</th></tr></thead>
        <tbody>
          <% wds.forEach(w=>{%>
          <tr>
            <td><strong><%= w.username %></strong></td>
            <td><strong style="color:var(--danger);">$<%= (w.amountUsd||0).toFixed(2) %></strong></td>
            <td style="font-size:.82rem;white-space:nowrap;">
              <span style="font-weight:700;"><%= w.networkLabel || w.cryptoType %></span>
              <% if(w.networkLabel && w.cryptoType){ %>
              <div style="font-size:.72rem;color:var(--text3);"><%= w.cryptoType %></div>
              <% } %>
            </td>
            <td>
              <div style="font-family:monospace;font-size:.78rem;color:var(--text);word-break:break-all;line-height:1.5;max-width:320px;"><%= w.walletAddress %></div>
              <button type="button" onclick="navigator.clipboard.writeText('<%= w.walletAddress %>').then(()=>{this.textContent='Copied!';setTimeout(()=>{this.textContent='Copy'},1500)})"
                style="background:none;border:1px solid var(--border);border-radius:4px;cursor:pointer;color:var(--blue);font-size:.68rem;padding:1px 8px;margin-top:.2rem;display:inline-block;">
                Copy
              </button>
            </td>
            <td><%- badge(w.status)%></td>
            <td style="font-size:.8rem;color:var(--text-muted);white-space:nowrap;"><%= new Date(w.createdAt).toLocaleString() %></td>
            <td>
              <% if(['pending','processing'].includes(w.status)){%>
              <div style="display:flex;gap:.35rem;flex-wrap:wrap;">
                <form method="POST" action="/admin/withdrawals/action" onsubmit="return confirm('Mark as completed and paid?')"><input type="hidden" name="wd_id" value="<%= w._id %>"><input type="hidden" name="action" value="complete"><button class="btn btn-success btn-sm"><i class="fas fa-check"></i> Done</button></form>
                <% if(w.status==='pending'){%><form method="POST" action="/admin/withdrawals/action"><input type="hidden" name="wd_id" value="<%= w._id %>"><input type="hidden" name="action" value="process"><button class="btn btn-outline btn-sm" title="Mark Processing"><i class="fas fa-cog"></i></button></form><%}%>
                <form method="POST" action="/admin/withdrawals/action" onsubmit="return confirm('Reject and refund balance to user?')"><input type="hidden" name="wd_id" value="<%= w._id %>"><input type="hidden" name="action" value="reject"><button class="btn btn-danger btn-sm" title="Reject &amp; Refund"><i class="fas fa-times"></i></button></form>
              </div>
              <%}%>
            </td>
          </tr>
          <%})%>
        </tbody>
      </table></div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
