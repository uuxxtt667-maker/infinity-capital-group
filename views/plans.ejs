  .pl-hiw-step:not(:last-child)::after { content:''; position:absolute; top:24px; left:calc(50% + 30px); width:calc(100% - 60px); height:1px; background:linear-gradient(90deg,rgba(61,142,240,.35),rgba(61,142,240,.08)); }
  .pl-hiw-num { width:48px; height:48px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1rem; font-weight:900; position:relative; z-index:1; }
