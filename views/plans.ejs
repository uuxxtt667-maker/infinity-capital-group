  .pl-hiw-sub { font-size:.75rem; color:#5a6380; text-align:center; line-height:1.45; }

  .pl-calc { background:#131726; border:1px solid #1e2540; border-radius:20px; padding:1.75rem; margin-bottom:3rem; }
  .pl-calc h4 { font-size:1rem; font-weight:800; color:#fff; margin:0 0 1.35rem; display:flex; align-items:center; gap:.5rem; }
  .pl-calc-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; }
  .pl-calc-result { background:rgba(0,230,118,.05); border:1px solid rgba(0,230,118,.1); border-radius:12px; padding:1.25rem; display:flex; flex-direction:column; justify-content:center; gap:.4rem; }
  .pl-calc-result .cr-lbl { font-size:.72rem; color:#5a6380; font-weight:600; }
  .pl-calc-result .cr-val { font-size:1.4rem; font-weight:900; color:#00e676; }
