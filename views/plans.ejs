  .pl-trust { display:flex; align-items:center; justify-content:center; gap:3rem; padding:1.25rem 1.75rem; background:#0e1020; border-top:1px solid #1a1f35; border-bottom:1px solid #1a1f35; flex-wrap:wrap; margin-top:2.5rem; }
