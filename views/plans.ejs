<!-- HERO -->
<div class="pl-hero">
  <div class="pl-hero-badge"><i class="fas fa-shield-alt"></i> <%- siteCustomize.heroBadge %></div>
  <h1><%- siteCustomize.heroTitle %></h1>
  <p><%- siteCustomize.heroSubtitle %></p>
</div>

<!-- STATS BAR -->
<div class="pl-stats">
  <div class="pl-stat"><div class="pl-stat-val" style="color:#f5a623"><%- siteCustomize.stat1Val %></div><div class="pl-stat-lbl"><%- siteCustomize.stat1Lbl %></div></div>
  <div class="pl-stat"><div class="pl-stat-val" style="color:#3d8ef0"><%- siteCustomize.stat2Val %></div><div class="pl-stat-lbl"><%- siteCustomize.stat2Lbl %></div></div>
  <div class="pl-stat"><div class="pl-stat-val" style="color:#9b59b6"><%- siteCustomize.stat3Val %></div><div class="pl-stat-lbl"><%- siteCustomize.stat3Lbl %></div></div>
  <div class="pl-stat"><div class="pl-stat-val" style="color:#00e676"><%- siteCustomize.stat4Val %></div><div class="pl-stat-lbl"><%- siteCustomize.stat4Lbl %></div></div>
</div>

<div class="pl-wrap">

  <div class="pl-section-hdr">
    <h2><%- siteCustomize.plansTitle %></h2>
    <p><%- siteCustomize.plansSubtitle %></p>
    <% if (gridPlans[popularIdx]) { %>
    <span style="display:inline-flex;align-items:center;gap:.4rem;background:rgba(245,166,35,.1);border:1px solid rgba(245,166,35,.2);color:#f5a623;font-size:.72rem;font-weight:700;padding:.3rem .9rem;border-radius:12px"><i class="fas fa-fire"></i> MOST POPULAR &mdash; <%= gridPlans[popularIdx].name %>: Best value for mid-tier investors</span>
    <% } %>
  </div>

  <!-- PLAN CARDS -->
  <div class="pl-grid">
    <% gridPlans.forEach(function(p, idx) {
      const isPopular  = (idx === popularIdx);
      const c          = p.color || '#3d8ef0';
      const annRoi     = p.annualRoi !== undefined ? p.annualRoi : (p.dailyRoi || 0);
      const totalRet   = (p.price * annRoi / 100 * (p.durationDays / 365)).toFixed(0);
      const dailyEst   = (p.price * annRoi / 100 / 365).toFixed(4);
      const feats      = (p.features || '').split('\n').map(f => f.trim()).filter(Boolean);
    %>
    <div class="pl-card <%= isPopular ? 'featured' : '' %>"
         style="border-color:<%= c %>40;<%= isPopular ? 'background:linear-gradient(158deg,#0d1525 0%,#131726 55%);box-shadow:0 0 32px '+c+'22;' : '' %>">
      <% if (isPopular) { %><div class="pl-popular-pill"><i class="fas fa-fire"></i> MOST POPULAR</div><% } %>

      <div class="pl-tier-lbl" style="color:<%= c %>90"><i class="<%= p.icon %>"></i></div>
      <div class="pl-name" style="color:#fff"><i class="<%= p.icon %>" style="color:<%= c %>"></i> <%= p.name.toUpperCase() %></div>

      <div class="pl-rate" style="color:<%= c %>"><%= annRoi %>%</div>
      <div class="pl-rate-lbl">Annual ROI</div>

      <!-- Investment range -->
      <div class="pl-inv-range">
        <div class="pl-inv-lbl">Investment Range</div>
        <div class="pl-inv-val">
          $<%= (p.price||0).toLocaleString() %>
          <% if (p.maxPrice > 0) { %> &ndash; $<%= p.maxPrice.toLocaleString() %><% } else { %> &ndash; Unlimited<% } %>
        </div>
      </div>

      <!-- Meta: duration + withdrawal -->
      <div class="pl-meta">
        <div class="pl-meta-item">
          <div class="pl-meta-lbl">Duration</div>
          <div class="pl-meta-val"><%= p.durationDays %> days</div>
        </div>
        <div class="pl-meta-item">
          <div class="pl-meta-lbl">Withdrawals</div>
          <div class="pl-meta-val"><%= p.withdrawalFreq || 'Monthly' %></div>
        </div>
      </div>

      <!-- Features -->
      <ul class="pl-feats">
        <li><i class="fas fa-check"></i> <%= annRoi %>% annual return</li>
        <li><i class="fas fa-check"></i> ~$<%= dailyEst %>/day on min. investment</li>
        <li><i class="fas fa-check"></i> <%= p.withdrawalFreq || 'Monthly' %> withdrawals</li>
        <% feats.forEach(function(f) { %>
        <li><i class="fas fa-check"></i> <%= f %></li>
        <% }); %>
        <% var refRate = (p.referralCommission !== undefined && p.referralCommission !== null && p.referralCommission !== '') ? p.referralCommission : null; %>
        <li><i class="fas fa-user-friends" style="color:#3d8ef0"></i>
          <% if (refRate !== null) { %>
            <strong style="color:#3d8ef0"><%= refRate %>% referral commission</strong> — instant payout
          <% } else { %>
            Referral commission — instant payout
          <% } %>
        </li>
      </ul>

      <!-- Earnings box -->
      <% if (totalRet > 0) { %>
      <div class="pl-earns">
        <span>$<%= (p.price||0).toLocaleString() %> invested &rarr;</span>
        <strong>+$<%= Number(totalRet).toLocaleString() %> total</strong>
        <span style="font-size:.72rem;"> over <%= p.durationDays %> days</span>
      </div>
      <% } %>

      <!-- CTA -->
      <% if (user) { %>
        <% if (user.planId === p._id && planActive) { %>
          <span class="pl-btn active-plan" style="background:<%= c %>22;color:<%= c %>;border-color:<%= c %>44"><i class="fas fa-check"></i> Active Plan</span>
        <% } else { %>
          <a href="/invest?plan=<%= p._id %>" class="pl-btn"
             style="background:<%= isPopular ? c : c+'18' %>;color:<%= isPopular ? '#000' : c %>;border-color:<%= c %>44;">
            Invest in <%= p.name %> &rarr;
          </a>
        <% } %>
      <% } else { %>
        <a href="/register" class="pl-btn" style="background:<%= isPopular ? c : c+'18' %>;color:<%= isPopular ? '#000' : c %>;border-color:<%= c %>44;">
          Get Started &rarr;
        </a>
      <% } %>
    </div>
    <% }); %>
  </div><!-- /pl-grid -->

  <!-- ELITE / LAST PLAN -->
  <% if (elitePlan) {
    const ec       = elitePlan.color || '#f5a623';
    const eliteRoi = elitePlan.annualRoi !== undefined ? elitePlan.annualRoi : (elitePlan.dailyRoi || 0);
    const eliteRet = (elitePlan.price * eliteRoi / 100 * (elitePlan.durationDays / 365)).toFixed(0);
    const eliteDay = (elitePlan.price * eliteRoi / 100 / 365).toFixed(4);
    const elFeats  = (elitePlan.features || '').split('\n').map(f => f.trim()).filter(Boolean);
  %>
  <div class="pl-elite" style="background:linear-gradient(135deg,#1a1200,#211800,#1a1200);border:1px solid <%= ec %>44;">
    <div class="pl-elite-tag"><i class="<%= elitePlan.icon %>"></i> EXCLUSIVE TIER</div>
    <div class="pl-elite-inner">
      <div>
        <div style="font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:<%= ec %>55;margin-bottom:.25rem;">Final Frontier</div>
        <div style="font-size:1.4rem;font-weight:900;color:<%= ec %>;display:flex;align-items:center;gap:.5rem;margin-bottom:.25rem;"><i class="<%= elitePlan.icon %>"></i> <%= elitePlan.name.toUpperCase() %></div>
        <div style="font-size:4.2rem;font-weight:900;color:<%= ec %>;line-height:1;letter-spacing:-.03em;"><%= eliteRoi %>%</div>
        <div style="font-size:.78rem;color:<%= ec %>80;margin-top:.15rem;">Annual ROI</div>
      </div>
      <div style="text-align:center;">
        <div style="font-size:.72rem;color:<%= ec %>80;margin-bottom:.3rem;">Investment Range</div>
        <div style="font-size:1.8rem;font-weight:900;color:#fff;">
          $<%= (elitePlan.price||0).toLocaleString() %>
          <% if (elitePlan.maxPrice > 0) { %>
          <span style="font-size:1rem;color:<%= ec %>80;"> – $<%= elitePlan.maxPrice.toLocaleString() %></span>
          <% } %>
        </div>
        <div style="font-size:.78rem;color:<%= ec %>80;margin-top:.4rem;">
          Duration: <strong style="color:<%= ec %>"><%= elitePlan.durationDays %> days</strong>
          &bull; Withdrawals: <strong style="color:<%= ec %>"><%= elitePlan.withdrawalFreq || 'Monthly' %></strong>
        </div>
        <% if (eliteRet > 0) { %>
        <div style="font-size:.8rem;color:<%= ec %>80;margin-top:.4rem;">$<%= (elitePlan.price||0).toLocaleString() %> &rarr; earns <strong style="color:<%= ec %>">+$<%= Number(eliteRet).toLocaleString() %> total</strong></div>
        <% } %>
      </div>
      <ul class="pl-elite-feats" style="color:<%= ec %>cc;">
        <li><i class="fas fa-check" style="color:<%= ec %>"></i> <%= eliteRoi %>% annual return</li>
        <li><i class="fas fa-check" style="color:<%= ec %>"></i> ~$<%= eliteDay %>/day on min.</li>
        <% elFeats.slice(0,6).forEach(function(f){ %>
        <li><i class="fas fa-check" style="color:<%= ec %>"></i> <%= f %></li>
        <% }); %>
        <% if (!elFeats.length) { %>
        <li><i class="fas fa-check" style="color:<%= ec %>"></i> Priority withdrawals</li>
        <li><i class="fas fa-check" style="color:<%= ec %>"></i> VIP account manager</li>
        <li><i class="fas fa-check" style="color:<%= ec %>"></i> Capital protection guarantee</li>
        <li><i class="fas fa-check" style="color:<%= ec %>"></i> Compound interest option</li>
        <% } %>
        <% var elRefRate = (elitePlan.referralCommission !== undefined && elitePlan.referralCommission !== null && elitePlan.referralCommission !== '') ? elitePlan.referralCommission : null; %>
        <li><i class="fas fa-user-friends" style="color:<%= ec %>"></i>
          <% if (elRefRate !== null) { %><strong><%= elRefRate %>% referral commission</strong> — instant<% } else { %>Referral commission — instant<% } %>
        </li>
      </ul>
      <div style="text-align:center;">
        <% if (user) { %>
          <% if (user.planId === elitePlan._id && planActive) { %>
            <span class="pl-elite-btn" style="background:<%= ec %>22;color:<%= ec %>;border:1px solid <%= ec %>44;opacity:.65;cursor:default"><i class="fas fa-check"></i> Active Plan</span>
          <% } else { %>
            <a href="/invest?plan=<%= elitePlan._id %>" class="pl-elite-btn" style="background:linear-gradient(135deg,<%= ec %>,<%= ec %>cc);color:#000;box-shadow:0 8px 28px <%= ec %>40;">
              <i class="<%= elitePlan.icon %>"></i> Join <%= elitePlan.name %> &rarr;
            </a>
          <% } %>
        <% } else { %>
          <a href="/register" class="pl-elite-btn" style="background:linear-gradient(135deg,<%= ec %>,<%= ec %>cc);color:#000;box-shadow:0 8px 28px <%= ec %>40;">
            <i class="<%= elitePlan.icon %>"></i> Get Started &rarr;
          </a>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>

