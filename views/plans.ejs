<% pageTitle = 'Investment Plans' %>
<%
  const paidPlans  = plans.filter(p => p.price > 0);
  const gridPlans  = paidPlans.length > 1 ? paidPlans.slice(0, -1) : paidPlans;
  const elitePlan  = paidPlans.length > 1 ? paidPlans[paidPlans.length - 1] : null;
  const popularIdx = gridPlans.length >= 3 ? 2 : Math.floor(gridPlans.length / 2);
  const cols       = Math.min(4, Math.max(1, gridPlans.length));
%>
<%- include('partials/head') %>
<%- include('partials/nav') %>
<%- include('partials/statsbar') %>

<!-- ── LIVE CRYPTO TICKER ── -->
<style>
.pl-ticker { background:#070c18; border-bottom:1px solid #1a1f35; overflow:hidden; white-space:nowrap; padding:.5rem 0; position:relative; }
.pl-ticker::before,.pl-ticker::after { content:''; position:absolute; top:0; width:60px; height:100%; z-index:2; pointer-events:none; }
.pl-ticker::before { left:0;  background:linear-gradient(to right, #070c18, transparent); }
.pl-ticker::after  { right:0; background:linear-gradient(to left,  #070c18, transparent); }
.pl-ticker-track { display:inline-flex; animation:plTickAnim 40s linear infinite; }
.pl-ticker-track:hover { animation-play-state:paused; }
@keyframes plTickAnim { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
.pl-tick-item { display:inline-flex; align-items:center; gap:.4rem; padding:0 1.2rem; border-right:1px solid rgba(26,31,53,.9); font-size:.74rem; white-space:nowrap; }
.pl-tick-sym  { font-weight:800; color:#e2e8f0; font-size:.72rem; }
.pl-tick-px   { font-weight:700; color:#f1f5f9; font-variant-numeric:tabular-nums; }
.pl-tick-chg.up { color:#00e676; font-weight:700; }
.pl-tick-chg.dn { color:#ff4757; font-weight:700; }
</style>
<div class="pl-ticker">
  <div class="pl-ticker-track" id="pl-tick-track">
    <!-- JS fills in 2× set for seamless loop -->
  </div>
</div>
<script>
(function(){
  var COINS=[
    {sym:'BTC/USDT',pair:'BTCUSDT',price:77525,chg:2.41},
    {sym:'ETH/USDT',pair:'ETHUSDT',price:2116,chg:1.82},
    {sym:'BNB/USDT',pair:'BNBUSDT',price:661,chg:0.93},
    {sym:'SOL/USDT',pair:'SOLUSDT',price:86,chg:3.14},
    {sym:'XRP/USDT',pair:'XRPUSDT',price:1.36,chg:-0.67},
    {sym:'DOGE/USDT',pair:'DOGEUSDT',price:0.1029,chg:-1.04},
    {sym:'ADA/USDT',pair:'ADAUSDT',price:0.2458,chg:1.22},
    {sym:'TRX/USDT',pair:'TRXUSDT',price:0.3666,chg:0.55},
    {sym:'AVAX/USDT',pair:'AVAXUSDT',price:9.42,chg:-1.23},
    {sym:'TON/USDT',pair:'TONUSDT',price:1.81,chg:2.10}
  ];
  var pMap={};
  COINS.forEach(function(c){ pMap[c.pair]=c; });

  function fmtPx(p){
    if(p>=10000) return '$'+p.toLocaleString('en-US',{maximumFractionDigits:0});
    if(p>=100)   return '$'+p.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
    if(p>=1)     return '$'+p.toFixed(3);
    if(p>=0.01)  return '$'+p.toFixed(4);
    return '$'+p.toFixed(6);
  }
  function buildHTML(){
    var html='';
    function row(c){
      var up=c.chg>=0;
      return '<span class="pl-tick-item">'+
        '<span class="pl-tick-sym">'+c.sym+'</span>'+
        '<span class="pl-tick-px" id="pltk-'+c.pair+'">'+fmtPx(c.price)+'</span>'+
        '<span class="pl-tick-chg '+(up?'up':'dn')+'" id="pltkc-'+c.pair+'">'+(up?'▲':'▼')+Math.abs(c.chg).toFixed(2)+'%</span>'+
      '</span>';
    }
    COINS.forEach(function(c){ html+=row(c); });
    COINS.forEach(function(c){ html+=row(c); }); /* duplicate for seamless loop */
    return html;
  }
  document.getElementById('pl-tick-track').innerHTML=buildHTML();

  var streams=COINS.map(function(c){ return c.pair.toLowerCase()+'@miniTicker'; }).join('/');
  var plRetry=1000;
  function connectWS(){
    try{
      var ws=new WebSocket('wss://stream.binance.com:9443/stream?streams='+streams);
      ws.onmessage=function(e){
        try{
          var msg=JSON.parse(e.data),d=msg.data||msg;
          var price=parseFloat(d.c),open=parseFloat(d.o);
          var chg=(price-open)/open*100;
          var sym=(d.s||'').toUpperCase();
          var c=pMap[sym]; if(!c) return;
          c.price=price; c.chg=chg;
          var upStr=(chg>=0?'▲':'▼')+Math.abs(chg).toFixed(2)+'%';
          var cls='pl-tick-chg '+(chg>=0?'up':'dn');
          document.querySelectorAll('[id="pltk-'+sym+'"]').forEach(function(el){ el.textContent=fmtPx(price); });
          document.querySelectorAll('[id="pltkc-'+sym+'"]').forEach(function(el){ el.textContent=upStr; el.className=cls; });
          plRetry=1000;
        }catch(_){}
      };
      ws.onclose=function(){ plRetry=Math.min(plRetry*1.5,30000); setTimeout(connectWS,plRetry); };
      ws.onerror=function(){ ws.close(); };
    }catch(_){}
  }
  connectWS();
})();
</script>

