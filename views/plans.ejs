  .pl-elite { position:relative; border-radius:20px; padding:2rem 2.25rem; margin-top:1.25rem; overflow:hidden; }
  .pl-elite::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 15% 50%, rgba(255,255,255,.06) 0%, transparent 55%); pointer-events:none; }
  .pl-elite-tag { position:absolute; top:1.4rem; right:1.75rem; background:linear-gradient(90deg,#f5a623,#e08a10); color:#000; font-size:.67rem; font-weight:800; letter-spacing:.1em; text-transform:uppercase; padding:.3rem 1rem; border-radius:20px; display:flex; align-items:center; gap:.35rem; }
  .pl-elite-inner { display:grid; grid-template-columns:auto 1fr 1fr auto; gap:2.25rem; align-items:center; position:relative; z-index:1; }
