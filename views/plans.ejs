  @media(max-width:1100px){ .pl-grid{grid-template-columns:repeat(2,1fr)} .pl-stats{grid-template-columns:repeat(4,1fr)} .pl-elite-inner{grid-template-columns:1fr 1fr;gap:1.5rem} .pl-calc-grid{grid-template-columns:1fr} }
  @media(max-width:760px){ .pl-grid{grid-template-columns:1fr 1fr} .pl-stats{grid-template-columns:repeat(2,1fr)} .pl-elite-inner{grid-template-columns:1fr;text-align:center} .pl-elite-feats{grid-template-columns:1fr} .pl-hiw-steps{flex-wrap:wrap;gap:1.5rem} .pl-hiw-step::after{display:none} }
