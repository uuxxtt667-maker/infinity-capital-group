  <!-- ROI CALCULATOR -->
  <div class="pl-calc">
    <h4><i class="fas fa-calculator" style="color:#3d8ef0"></i> Annual ROI Calculator</h4>
    <div class="pl-calc-grid">
      <div>
        <div class="form-group">
          <label class="form-label">Select Plan</label>
          <select class="form-control" id="calc-plan" onchange="calcROI()">
            <% paidPlans.forEach(function(p) {
              const roi = p.annualRoi !== undefined ? p.annualRoi : (p.dailyRoi || 0);
            %>
            <option value="<%= p.price %>:<%= roi %>:<%= p.durationDays %>">
              <%= p.name %> — $<%= (p.price||0).toLocaleString() %> min &middot; <%= roi %>% / year
            </option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Investment Amount ($)</label>
          <input type="number" id="calc-amount" class="form-control"
            value="<%= paidPlans[0] ? paidPlans[0].price : 500 %>"
            min="0" oninput="calcROI()">
        </div>
      </div>
      <div class="pl-calc-result">
        <div class="cr-lbl">Projected Earnings</div>
        <div class="cr-val" id="calc-total">—</div>
        <div class="cr-sub" id="calc-daily">—</div>
        <div class="cr-note" id="calc-note">—</div>
      </div>
    </div>
  </div>

</div><!-- /pl-wrap -->

<script>
function calcROI() {
  var parts  = document.getElementById('calc-plan').value.split(':');
  var minAmt = +parts[0], annRate = +parts[1], days = +parts[2];
  var amtEl  = document.getElementById('calc-amount');
  var amt    = Math.max(minAmt, +amtEl.value || minAmt);
  amtEl.min  = minAmt;
  if (+amtEl.value < minAmt) amtEl.value = minAmt;

  var annual  = amt * annRate / 100;
  var total   = annual * days / 365;
  var daily   = annual / 365;

  document.getElementById('calc-total').textContent = 'Total: $' + total.toLocaleString('en-US', {maximumFractionDigits:2});
  document.getElementById('calc-daily').textContent = 'Daily: $' + daily.toLocaleString('en-US', {maximumFractionDigits:4}) + ' &bull; Annual: $' + annual.toLocaleString('en-US', {maximumFractionDigits:2});
  document.getElementById('calc-daily').innerHTML   = 'Daily: $' + daily.toFixed(4) + ' &bull; Annual: $' + annual.toFixed(2);
  document.getElementById('calc-note').textContent  = '$' + amt.toLocaleString() + ' at ' + annRate + '% p.a. for ' + days + ' days';
}
document.addEventListener('DOMContentLoaded', calcROI);
</script>

