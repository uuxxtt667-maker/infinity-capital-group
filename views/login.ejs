<% pageTitle = 'Sign In' %>
<%- include('partials/head') %>
<%- include('partials/nav') %>

<style>
/* ── LOGIN PAGE ── */
.lp-outer {
  min-height: calc(100vh - 68px);
  display: flex;
  align-items: stretch;
  position: relative;
  z-index: 1;
}

/* Left info panel */
.lp-left {
  flex: 1;
  background: linear-gradient(150deg, rgba(8,15,40,.92) 0%, rgba(14,25,60,.95) 100%);
  backdrop-filter: blur(6px);
  padding: 3.5rem 3rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border-right: 1px solid rgba(255,255,255,.1);
  position: relative;
  z-index: 1;
}
.lp-left::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 60% at 20% 50%, rgba(245,166,35,.12), transparent);
  pointer-events: none;
}
.lp-left h2 { font-size: clamp(1.6rem,2.8vw,2.2rem); font-weight: 900; color: #fff; line-height: 1.2; margin-bottom: .9rem; }
.lp-left p  { color: rgba(255,255,255,.6); font-size: .88rem; margin-bottom: 2rem; line-height: 1.65; }
.lp-chips   { display: flex; flex-wrap: wrap; gap: .55rem; margin-bottom: 2rem; }
.lp-chip    { font-size: .7rem; font-weight: 800; padding: .3rem .85rem; border-radius: 20px; letter-spacing: .06em; }
.lp-stats   { display: flex; gap: 1.5rem; }
.lp-stat    { text-align: center; }
.lp-stat-v  { font-size: 1.35rem; font-weight: 900; color: #fff; }
.lp-stat-l  { font-size: .7rem; color: rgba(255,255,255,.5); font-weight: 600; }

/* Right form panel */
.lp-right {
  width: 480px;
  flex-shrink: 0;
  background: var(--card);
  padding: 3rem 2.75rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  z-index: 1;
  overflow-y: auto;
}
.lp-logo   { font-size: 1.1rem; font-weight: 900; color: var(--text); margin-bottom: 1.6rem; text-align: center; }
.lp-logo span { color: var(--gold); }
.lp-title  { font-size: 1.35rem; font-weight: 800; color: var(--text); text-align: center; margin-bottom: .3rem; }
.lp-sub    { font-size: .82rem; color: var(--text3); text-align: center; margin-bottom: 1.75rem; }

.lp-input-wrap { position: relative; margin-bottom: 1rem; }
.lp-input-icon { position: absolute; left: .9rem; top: 50%; transform: translateY(-50%); color: var(--text3); font-size: .85rem; }
.lp-input {
  width: 100%;
  padding: .72rem 1rem .72rem 2.4rem;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  background: var(--bg2);
  color: var(--text);
  font-size: .9rem;
  outline: none;
  transition: border-color .2s, box-shadow .2s;
  box-sizing: border-box;
}
.lp-input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-light); }
.lp-input::placeholder { color: var(--text3); }
.lp-label { font-size: .75rem; font-weight: 700; color: var(--text2); margin-bottom: .4rem; display: block; }

.lp-remember { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.35rem; font-size: .8rem; color: var(--text3); }
.lp-remember label { display: flex; align-items: center; gap: .4rem; cursor: pointer; }

.lp-btn { width: 100%; padding: .82rem; border: none; border-radius: 11px; background: linear-gradient(135deg, var(--gold), var(--gold2)); color: #000; font-size: .95rem; font-weight: 800; cursor: pointer; transition: transform .15s, box-shadow .15s; margin-bottom: 1.25rem; }
.lp-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px var(--gold-light); }

.lp-divider { display: flex; align-items: center; gap: .75rem; color: var(--text3); font-size: .75rem; margin-bottom: 1.1rem; }
.lp-divider::before, .lp-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

.lp-social { display: flex; gap: .6rem; margin-bottom: 1.35rem; }
.lp-social-btn { flex: 1; padding: .6rem; border: 1px solid var(--border); border-radius: 8px; background: var(--bg2); color: var(--text2); font-size: .8rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: .4rem; transition: background .15s; }
.lp-social-btn:hover { background: var(--bg3); }

.lp-footer-txt { text-align: center; font-size: .82rem; color: var(--text3); margin-bottom: 1rem; }
.lp-footer-txt a { color: var(--gold); font-weight: 700; text-decoration: none; }
.lp-security { display: flex; justify-content: center; gap: 1.25rem; }
.lp-sec-item { font-size: .7rem; color: var(--text3); display: flex; align-items: center; gap: .3rem; }

/* Password toggle */
.lp-pwd-wrap { position: relative; }
.lp-pwd-toggle { position: absolute; right: .85rem; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text3); cursor: pointer; padding: .2rem; font-size: .85rem; }

/* Responsive */
@media (max-width: 900px) { .lp-left { display: none; } }
@media (max-width: 520px) { .lp-right { width: 100%; padding: 2rem 1.5rem; } }
</style>

<div class="lp-outer">

  <!-- LEFT PANEL -->
  <div class="lp-left">
    <div style="position:relative;z-index:1">
      <div style="font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);margin-bottom:.6rem">
        <i class="fas fa-shield-alt" style="margin-right:.35rem"></i>Investor Portal
      </div>
      <h2>Welcome back to your<br>wealth dashboard</h2>
      <p>Sign in to track your returns, manage deposits, and monitor live crypto market performance across all your active investment plans.</p>
      <div class="lp-chips">
        <span class="lp-chip" style="background:rgba(192,192,192,.15);color:#c0c0c0;border:1px solid rgba(192,192,192,.2)">Silver 30%</span>
        <span class="lp-chip" style="background:rgba(255,215,0,.12);color:#ffd700;border:1px solid rgba(255,215,0,.2)">Gold 35%</span>
        <span class="lp-chip" style="background:rgba(185,242,255,.12);color:#b9f2ff;border:1px solid rgba(185,242,255,.2)">Platinum 40%</span>
        <span class="lp-chip" style="background:rgba(155,89,182,.15);color:#9b59b6;border:1px solid rgba(155,89,182,.25)">Diamond 45%</span>
        <span class="lp-chip" style="background:rgba(245,166,35,.12);color:#f5a623;border:1px solid rgba(245,166,35,.2)">Elite 50%</span>
      </div>
      <div class="lp-stats">
        <div class="lp-stat"><div class="lp-stat-v">$48M+</div><div class="lp-stat-l">Assets Managed</div></div>
        <div class="lp-stat"><div class="lp-stat-v">12.4K+</div><div class="lp-stat-l">Investors</div></div>
        <div class="lp-stat"><div class="lp-stat-v">50%</div><div class="lp-stat-l">Max Annual ROI</div></div>
        <div class="lp-stat"><div class="lp-stat-v">100%</div><div class="lp-stat-l">On-Time Payouts</div></div>
      </div>
    </div>
  </div>

  <!-- RIGHT FORM -->
  <div class="lp-right">
    <div class="lp-logo"><%= siteCustomize.logoText %><span><%= siteCustomize.logoAccent %></span></div>
    <div class="lp-title"><%= siteCustomize.loginTitle || 'Sign In' %></div>
    <div class="lp-sub"><%= siteCustomize.loginSubtitle || 'Access your investor dashboard' %></div>

    <form method="POST" action="/login" autocomplete="on">
      <input type="hidden" name="_csrf" value="<%= csrf %>">

      <label class="lp-label" for="lp-login">Username or Email</label>
      <div class="lp-input-wrap">
        <i class="fas fa-user lp-input-icon"></i>
        <input type="text" id="lp-login" name="login" class="lp-input"
          placeholder="Enter username or email" required autofocus autocomplete="username">
      </div>

      <label class="lp-label" for="lp-password">Password</label>
      <div class="lp-input-wrap lp-pwd-wrap">
        <i class="fas fa-lock lp-input-icon"></i>
        <input type="password" id="lp-password" name="password" class="lp-input"
          placeholder="Enter your password" required autocomplete="current-password">
        <button type="button" class="lp-pwd-toggle" onclick="togglePwd()" title="Show/hide password">
          <i class="fas fa-eye" id="pwd-eye"></i>
        </button>
      </div>

      <div class="lp-remember">
        <label><input type="checkbox" name="remember"> Keep me signed in</label>
        <a href="/forgot-password" style="color:var(--gold);text-decoration:none;font-size:.78rem">Forgot password?</a>
      </div>

      <button type="submit" class="lp-btn">
        <i class="fas fa-sign-in-alt" style="margin-right:.45rem"></i>Sign in to Dashboard
      </button>
    </form>

    <div class="lp-divider">or continue with</div>
    <div class="lp-social">
      <button class="lp-social-btn" onclick="alert('OAuth not configured')"><i class="fab fa-google" style="color:#ea4335"></i> Google</button>
      <button class="lp-social-btn" onclick="alert('OAuth not configured')"><i class="fab fa-apple"></i> Apple</button>
      <button class="lp-social-btn" onclick="alert('OAuth not configured')"><i class="fab fa-facebook" style="color:#1877f2"></i> Facebook</button>
    </div>

    <div class="lp-footer-txt">New investor? <a href="/register">Create an account &rarr;</a></div>
    <div class="lp-security">
      <span class="lp-sec-item"><i class="fas fa-lock"></i> 256-bit SSL</span>
      <span class="lp-sec-item"><i class="fas fa-mobile-alt"></i> 2FA ready</span>
      <span class="lp-sec-item"><i class="fas fa-shield-alt"></i> Secure &amp; Private</span>
    </div>
  </div>

</div>

<script>
function togglePwd() {
  var inp = document.getElementById('lp-password');
  var eye = document.getElementById('pwd-eye');
  if (inp.type === 'password') {
    inp.type = 'text';
    eye.className = 'fas fa-eye-slash';
  } else {
    inp.type = 'password';
    eye.className = 'fas fa-eye';
  }
}
</script>

<%- include('partials/footer') %>
