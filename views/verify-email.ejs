<% pageTitle = 'Verify Your Email' %>
<%- include('partials/head') %>
<%- include('partials/nav') %>

<style>
.otp-outer {
  min-height: calc(100vh - 68px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem 1rem;
  position: relative;
  z-index: 1;
}
.otp-card {
  width: 100%;
  max-width: 460px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 2.75rem 2.5rem 2.25rem;
  position: relative;
  z-index: 1;
}
.otp-icon {
  width: 64px; height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(245,166,35,.18), rgba(245,166,35,.05));
  border: 2px solid rgba(245,166,35,.35);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.6rem; color: var(--gold);
  margin: 0 auto 1.4rem;
}
.otp-title  { font-size: 1.35rem; font-weight: 800; color: var(--text); text-align: center; margin-bottom: .4rem; }
.otp-sub    { font-size: .84rem; color: var(--text3); text-align: center; margin-bottom: 2rem; line-height: 1.55; }
.otp-label  { font-size: .75rem; font-weight: 700; color: var(--text2); margin-bottom: .45rem; display: block; }
.otp-inputs {
  display: flex; gap: .55rem; justify-content: center;
  margin-bottom: 1.5rem;
}
.otp-digit {
  width: 52px; height: 60px;
  text-align: center;
  font-size: 1.6rem; font-weight: 800;
  border: 2px solid var(--border);
  border-radius: 12px;
  background: var(--bg2);
  color: var(--text);
  outline: none;
  transition: border-color .2s, box-shadow .2s;
  caret-color: transparent;
}
.otp-digit:focus { border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-light); }
.otp-digit.filled { border-color: var(--gold); }
.otp-hidden { display: none; }

.otp-btn {
  width: 100%; padding: .82rem;
  border: none; border-radius: 11px;
  background: linear-gradient(135deg, var(--gold), var(--gold2));
  color: #000; font-size: .95rem; font-weight: 800;
  cursor: pointer; transition: transform .15s, box-shadow .15s;
  margin-bottom: 1rem;
}
.otp-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px var(--gold-light); }

.otp-resend { text-align: center; font-size: .82rem; color: var(--text3); }
.otp-resend button {
  background: none; border: none; color: var(--gold); font-weight: 700;
  cursor: pointer; font-size: .82rem; padding: 0;
  text-decoration: underline; text-decoration-style: dotted;
}
.otp-timer { color: var(--text3); font-size: .78rem; margin-top: .35rem; text-align: center; }
</style>

<div class="otp-outer">
  <div class="otp-card">
    <div class="otp-icon"><i class="fas fa-envelope-open-text"></i></div>
    <div class="otp-title">Check Your Email</div>
    <div class="otp-sub">
      We sent a 6-digit verification code to your email address.<br>
      Enter it below to activate your account.
    </div>

    <form method="POST" action="/verify-email" id="otpForm">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <input type="hidden" name="otp" id="otpHidden">

      <label class="otp-label" style="text-align:center;display:block">Verification Code</label>
      <div class="otp-inputs" id="otpInputs">
        <input class="otp-digit" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="one-time-code">
        <input class="otp-digit" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
        <input class="otp-digit" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
        <input class="otp-digit" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
        <input class="otp-digit" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
        <input class="otp-digit" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
      </div>

      <button type="submit" class="otp-btn" id="otpSubmit" disabled>
        <i class="fas fa-check-circle" style="margin-right:.4rem"></i>Verify Email
      </button>
    </form>

    <div class="otp-resend">
      Didn't receive it?
      <form method="POST" action="/verify-email/resend" style="display:inline">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <button type="submit" id="resendBtn">Resend code</button>
      </form>
    </div>
    <div class="otp-timer" id="otpTimer"></div>
  </div>
</div>

<script>
(function(){
  var digits = Array.from(document.querySelectorAll('.otp-digit'));
  var hidden = document.getElementById('otpHidden');
  var submitBtn = document.getElementById('otpSubmit');

  function getCode(){
    return digits.map(function(d){ return d.value; }).join('');
  }
  function refreshHidden(){
    var c = getCode();
    hidden.value = c;
    submitBtn.disabled = c.length < 6;
    digits.forEach(function(d){ d.classList.toggle('filled', d.value !== ''); });
  }

  digits.forEach(function(d, i){
    d.addEventListener('input', function(){
      // accept paste of full code
      if(d.value.length > 1){
        var pasted = d.value.replace(/\D/g,'').slice(0,6);
        pasted.split('').forEach(function(ch, j){
          if(digits[j]) digits[j].value = ch;
        });
        var last = Math.min(pasted.length, 5);
        digits[last].focus();
        refreshHidden(); return;
      }
      d.value = d.value.replace(/\D/,'');
      if(d.value && i < 5) digits[i+1].focus();
      refreshHidden();
    });
    d.addEventListener('keydown', function(e){
      if(e.key==='Backspace' && !d.value && i > 0){ digits[i-1].focus(); digits[i-1].value=''; refreshHidden(); }
    });
    d.addEventListener('paste', function(e){
      e.preventDefault();
      var text = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g,'').slice(0,6);
      text.split('').forEach(function(ch, j){ if(digits[j]) digits[j].value=ch; });
      var last = Math.min(text.length, 5);
      digits[last].focus();
      refreshHidden();
    });
  });

  // 15-min countdown
  var expiry = Date.now() + 15*60*1000;
  var timerEl = document.getElementById('otpTimer');
  function tick(){
    var left = Math.max(0, expiry - Date.now());
    var m = Math.floor(left/60000);
    var s = Math.floor((left%60000)/1000);
    timerEl.textContent = 'Code expires in ' + m + ':' + (s<10?'0':'')+s;
    if(left > 0) setTimeout(tick, 1000);
    else timerEl.textContent = 'Code expired — please request a new one.';
  }
  tick();

  // Focus first box
  if(digits[0]) digits[0].focus();
})();
</script>

<%- include('partials/footer') %>
