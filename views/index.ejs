/* ── Binance WebSocket — all 10 landing-page pairs, real-time ── */
(function initBinanceWS(){
  const streams=[
    'btcusdt@miniTicker','ethusdt@miniTicker','bnbusdt@miniTicker',
    'solusdt@miniTicker','xrpusdt@miniTicker','dogeusdt@miniTicker',
    'adausdt@miniTicker','trxusdt@miniTicker','avaxusdt@miniTicker',
    'tonusdt@miniTicker'
  ].join('/');
  let ws,retryDelay=3000;

  function connect(){
    try{
      ws=new WebSocket('wss://stream.binance.com:9443/stream?streams='+streams);
      ws.onopen=()=>{ retryDelay=3000; };

      ws.onmessage=function(e){
        try{
          const msg=JSON.parse(e.data);
          const t=msg.data;
          if(!t||!t.s)return;
          const price=parseFloat(t.c);
          const open =parseFloat(t.o);
          const chg  =+((price-open)/open*100).toFixed(2);
          switch(t.s){
            case'BTCUSDT':
              fx.btc.price=price;fx.btc.chg=chg;
              cryptoHist[cryptoHist.length-1]=price;
              drawArea('mc-crypto',cryptoHist,'#f7931a','#f7931a');
              drawArea('ana-btc',cryptoHist,'#00e676','#00e676',60);
              break;
            case'ETHUSDT':
              fx.eth.price=price;fx.eth.chg=chg;
              ethHist[ethHist.length-1]=price;
              drawArea('mc-eth',ethHist,'#627eea','#627eea');
              drawArea('ana-eth',ethHist,'#627eea','#627eea',60);
              break;
            case'BNBUSDT':
              fx.bnb.price=price;fx.bnb.chg=chg;
              bnbHist[bnbHist.length-1]=price;
              drawArea('mc-bnb',bnbHist,'#f3ba2f','#f3ba2f');
              drawArea('ana-bnb',bnbHist,'#f3ba2f','#f3ba2f',60);
              break;
            case'SOLUSDT':
              fx.sol.price=price;fx.sol.chg=chg;
              solHist[solHist.length-1]=price;
              drawArea('mc-sol',solHist,'#9945ff','#9945ff');
              drawArea('ana-sol',solHist,'#9945ff','#9945ff',60);
              break;
            case'XRPUSDT': fx.xrp.price=price;fx.xrp.chg=chg;break;
            case'DOGEUSDT':fx.doge.price=price;fx.doge.chg=chg;break;
            case'ADAUSDT': fx.ada.price=price;fx.ada.chg=chg;break;
            case'TRXUSDT': fx.trx.price=price;fx.trx.chg=chg;break;
            case'AVAXUSDT':fx.avax.price=price;fx.avax.chg=chg;break;
            case'TONUSDT': fx.ton.price=price;fx.ton.chg=chg;break;
          }
          updateTicker();
        }catch(_){}
      };

      ws.onclose=()=>{ retryDelay=Math.min(retryDelay*1.5,30000); setTimeout(connect,retryDelay); };
      ws.onerror=()=>ws.close();
    }catch(_){setTimeout(connect,retryDelay);}
  }
  connect();
})();

/* ══════════════════════════════════════════════
   AOS SCROLL ANIMATION
══════════════════════════════════════════════ */
function initAOS(){
  const els=document.querySelectorAll('[data-aos]');
  const io=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('aos-animate');}),{threshold:.12});
  els.forEach(e=>io.observe(e));
}

