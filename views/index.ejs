      cardBg:'#ffffff', bg2:'#f8fafc' };
  }
})();

/* ══════════════════════════════════════════════
   STATE — Top 10 crypto from Binance
══════════════════════════════════════════════ */
const fx = {
  btc: {price:77525, chg:2.41},
  eth: {price:2116,  chg:1.82},
  bnb: {price:661,   chg:0.93},
  sol: {price:86,    chg:3.14},
  xrp: {price:1.36,  chg:-0.67},
  doge:{price:0.1029,chg:-1.04},
  ada: {price:0.2458,chg:1.22},
  trx: {price:0.3666,chg:0.55},
  avax:{price:9.42,  chg:-1.23},
  ton: {price:1.81,  chg:2.10}
};
const cryptoHist=[58000,60500,64800,62000,66200,70400,fx.btc.price];
const ethHist   =[1800,1900,2000,2050,2080,2100,fx.eth.price];
const bnbHist   =[500,550,580,620,640,655,fx.bnb.price];
const solHist   =[60,68,75,80,82,84,fx.sol.price];

/* ══════════════════════════════════════════════
   HELPERS
══════════════════════════════════════════════ */
const $=id=>document.getElementById(id);
const fmtN=(n,d=0)=>n.toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d});
function getCtx(id,H=100){
  const c=$(id);if(!c)return null;
  const W=c.offsetWidth||260;const h=c.offsetHeight||H;
  c.width=W*devicePixelRatio;c.height=h*devicePixelRatio;
  const ctx=c.getContext('2d');ctx.scale(devicePixelRatio,devicePixelRatio);
  return{ctx,W,H:h};
}

/* ══════════════════════════════════════════════
   ROTATING GLOBE
══════════════════════════════════════════════ */
function drawBtcCoin(){
  const c=$('globeCanvas');if(!c)return;
  const sz=400,dpr=Math.min(window.devicePixelRatio||1,2);
  c.width=c.height=sz*dpr;c.style.width=c.style.height=sz+'px';
  const ctx=c.getContext('2d');ctx.scale(dpr,dpr);
  const cx=sz/2,cy=sz/2,r=178;let rot=0;

  function project(lat,lon){
    const phi=lat*Math.PI/180,theta=(lon+rot)*Math.PI/180;
    const x=r*Math.cos(phi)*Math.sin(theta),y=r*Math.sin(phi),z=r*Math.cos(phi)*Math.cos(theta);
    return{x:cx+x,y:cy-y,z,v:z>0};
  }

  function frame(){
    ctx.clearRect(0,0,sz,sz);
    /* globe body */
    const gb=ctx.createRadialGradient(cx-r*.22,cy-r*.25,r*.05,cx,cy,r);
    gb.addColorStop(0,'#7ab8ff');gb.addColorStop(.28,'#4a9ef5');gb.addColorStop(.6,'#2563eb');gb.addColorStop(1,'#0f2d7a');
    ctx.fillStyle=gb;ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.fill();
    /* latitude lines */
    for(let lat=-75;lat<=75;lat+=15){
      ctx.beginPath();let f=true;
      for(let lon=0;lon<=360;lon+=3){
        const p=project(lat,lon);if(!p.v){f=true;continue;}
        const a=Math.max(0,p.z/r)*.55+.1;
        ctx.strokeStyle=`rgba(255,255,255,${a})`;ctx.lineWidth=.7;
        if(f){ctx.moveTo(p.x,p.y);f=false;}else ctx.lineTo(p.x,p.y);
      }ctx.stroke();
    }
    /* longitude lines */
    for(let lon=0;lon<360;lon+=15){
      ctx.beginPath();let f=true;
      for(let lat=-90;lat<=90;lat+=3){
        const p=project(lat,lon);if(!p.v){f=true;continue;}
        const a=Math.max(0,p.z/r)*.45+.08;
        ctx.strokeStyle=`rgba(255,255,255,${a})`;ctx.lineWidth=.7;
        if(f){ctx.moveTo(p.x,p.y);f=false;}else ctx.lineTo(p.x,p.y);
      }ctx.stroke();
    }
    /* dot intersections */
    for(let lat=-75;lat<=75;lat+=15){
      for(let lon=0;lon<360;lon+=15){
        const p=project(lat,lon);if(!p.v)continue;
        const a=(p.z/r)*.55+.08;
        ctx.beginPath();ctx.arc(p.x,p.y,1.8,0,Math.PI*2);
        ctx.fillStyle=`rgba(180,220,255,${a})`;ctx.fill();
      }
    }
    /* ₿ symbol */
    ctx.save();
    ctx.font=`900 ${Math.round(r*.8)}px 'Arial Black',Arial,sans-serif`;
    ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillStyle='rgba(255,255,255,.88)';
    ctx.shadowColor='rgba(61,142,240,.7)';ctx.shadowBlur=22;
    ctx.fillText('₿',cx,cy);
    ctx.restore();
    /* highlight sheen */
    const sh=ctx.createRadialGradient(cx-r*.3,cy-r*.32,0,cx-r*.08,cy-r*.08,r*.9);
    sh.addColorStop(0,'rgba(255,255,255,.28)');sh.addColorStop(.45,'rgba(255,255,255,.08)');sh.addColorStop(1,'rgba(0,0,0,0)');
    ctx.save();ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.clip();ctx.fillStyle=sh;ctx.fillRect(0,0,sz,sz);ctx.restore();

    rot+=.12;requestAnimationFrame(frame);
  }
  frame();
  return; // everything below is unused — kept for future reference
  const R=sz; // dead code guard

  /* ─ clip helper ─ */
  function coinClip(){ctx.beginPath();ctx.arc(cx,cy,R,0,Math.PI*2);ctx.clip();}

  /* ─ wide outer glow ─ */
  const og=ctx.createRadialGradient(cx,cy,R*.45,cx,cy,R*1.5);
  og.addColorStop(0,'rgba(160,0,0,0)');og.addColorStop(.42,'rgba(200,0,0,.16)');
  og.addColorStop(.66,'rgba(230,0,0,.38)');og.addColorStop(.84,'rgba(180,0,0,.22)');og.addColorStop(1,'rgba(90,0,0,0)');
  ctx.fillStyle=og;ctx.beginPath();ctx.arc(cx,cy,R*1.5,0,Math.PI*2);ctx.fill();
  const ig=ctx.createRadialGradient(cx,cy,R*.78,cx,cy,R*1.08);
  ig.addColorStop(0,'rgba(255,0,0,0)');ig.addColorStop(.5,'rgba(255,10,0,.6)');ig.addColorStop(1,'rgba(200,0,0,0)');
  ctx.fillStyle=ig;ctx.beginPath();ctx.arc(cx,cy,R*1.08,0,Math.PI*2);ctx.fill();

  /* ─ coin body ─ */
  const bg=ctx.createRadialGradient(cx-R*.2,cy-R*.24,R*.05,cx,cy,R);
  bg.addColorStop(0,'#220505');bg.addColorStop(.3,'#160303');bg.addColorStop(.65,'#0d0202');bg.addColorStop(1,'#050101');
  ctx.fillStyle=bg;ctx.beginPath();ctx.arc(cx,cy,R,0,Math.PI*2);ctx.fill();

  /* directional sheen – top-left lighter */
  const sh=ctx.createRadialGradient(cx-R*.28,cy-R*.32,0,cx-R*.05,cy-R*.05,R*1.1);
  sh.addColorStop(0,'rgba(255,80,80,.1)');sh.addColorStop(.5,'rgba(255,30,30,.04)');sh.addColorStop(1,'rgba(0,0,0,0)');
  ctx.fillStyle=sh;ctx.save();coinClip();ctx.fillRect(0,0,sz,sz);ctx.restore();

  /* ─ outer neon rim ─ */
  ctx.save();
  ctx.shadowColor='#ff0000';ctx.shadowBlur=28;
  ctx.strokeStyle='#dd0000';ctx.lineWidth=5;
  ctx.beginPath();ctx.arc(cx,cy,R-2.5,0,Math.PI*2);ctx.stroke();
  ctx.shadowBlur=12;ctx.strokeStyle='rgba(255,50,50,.25)';ctx.lineWidth=2;
  ctx.beginPath();ctx.arc(cx,cy,R-12,0,Math.PI*2);ctx.stroke();
  ctx.restore();

  /* ─ rim LED strip (every 5°) ─ */
  const ledR=R-20;
  for(let i=0;i<72;i++){
    const a=(i/72)*Math.PI*2,bright=i%6===0;
    ctx.save();ctx.shadowColor='#ff0000';ctx.shadowBlur=bright?9:3;
    ctx.fillStyle=bright?'#ff1a1a':'rgba(160,0,0,.45)';
    ctx.beginPath();ctx.arc(cx+ledR*Math.cos(a),cy+ledR*Math.sin(a),bright?2.8:1.5,0,Math.PI*2);ctx.fill();
    ctx.restore();
  }

  /* ─ circular rim text ─ */
  ctx.save();
  const rimTxt='BITCOIN•2140•01000010•01000011•SATOSHI•NAKAMOTO•SHA256•BLOCKCHAIN•';
  const txtR=R-36;
  ctx.font='bold 7px monospace';ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillStyle='rgba(200,0,0,.55)';
  for(let i=0;i<rimTxt.length;i++){
    const a=(i/rimTxt.length)*Math.PI*2-Math.PI/2;
    ctx.save();ctx.translate(cx+txtR*Math.cos(a),cy+txtR*Math.sin(a));ctx.rotate(a+Math.PI/2);
    ctx.fillText(rimTxt[i],0,0);ctx.restore();
  }
  ctx.restore();

  /* ─ 8 concentric circuit rings ─ */
  const rRings=[R*.86,R*.76,R*.67,R*.59,R*.51,R*.43,R*.35,R*.27];
  rRings.forEach((r,i)=>{
    const alpha=.18+i*.025;
    ctx.strokeStyle=`rgba(145,0,0,${alpha})`;ctx.lineWidth=i<4?.9:.7;
    ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.stroke();
    if(i<5){
      const n=i===0?72:i<3?56:40;
      for(let t=0;t<n;t++){
        const a=(t/n)*Math.PI*2,bright=t%Math.round(n/8)===0;
        const len=bright?6:3;
        ctx.save();ctx.strokeStyle=bright?'rgba(180,0,0,.7)':'rgba(110,0,0,.45)';ctx.lineWidth=bright?.8:.45;
        ctx.beginPath();
        ctx.moveTo(cx+(r-len)*Math.cos(a),cy+(r-len)*Math.sin(a));
        ctx.lineTo(cx+(r+len)*Math.cos(a),cy+(r+len)*Math.sin(a));
        ctx.stroke();ctx.restore();
      }
    }
  });

  /* ─ radial circuit traces ─ */
  const traces=[
    [[cx+R*.07,cy-R*.04],[cx+R*.36,cy-R*.04],[cx+R*.36,cy-R*.24],[cx+R*.54,cy-R*.24]],
    [[cx+R*.07,cy+R*.04],[cx+R*.32,cy+R*.04],[cx+R*.32,cy+R*.22],[cx+R*.5,cy+R*.22],[cx+R*.5,cy+R*.38]],
    [[cx-R*.07,cy+R*.04],[cx-R*.36,cy+R*.04],[cx-R*.36,cy+R*.24],[cx-R*.54,cy+R*.24]],
    [[cx-R*.07,cy-R*.04],[cx-R*.32,cy-R*.04],[cx-R*.32,cy-R*.22],[cx-R*.5,cy-R*.22],[cx-R*.5,cy-R*.38]],
    [[cx+R*.04,cy-R*.08],[cx+R*.04,cy-R*.42],[cx+R*.22,cy-R*.42],[cx+R*.22,cy-R*.56]],
    [[cx-R*.04,cy+R*.08],[cx-R*.04,cy+R*.42],[cx-R*.22,cy+R*.42],[cx-R*.22,cy+R*.56]],
    [[cx+R*.18,cy-R*.32],[cx+R*.34,cy-R*.32]],
    [[cx-R*.18,cy+R*.32],[cx-R*.34,cy+R*.32]],
  ];
  ctx.save();ctx.strokeStyle='rgba(170,0,0,.68)';ctx.lineWidth=1.4;
  traces.forEach(pts=>{ctx.beginPath();pts.forEach(([x,y],i)=>i?ctx.lineTo(x,y):ctx.moveTo(x,y));ctx.stroke();});
  ctx.restore();

  /* ─ LED component dots ─ */
  const leds=[
    [cx+R*.36,cy-R*.24],[cx+R*.54,cy-R*.24],[cx+R*.5,cy+R*.38],
    [cx-R*.36,cy+R*.24],[cx-R*.54,cy+R*.24],[cx-R*.5,cy-R*.38],
    [cx+R*.22,cy-R*.56],[cx-R*.22,cy+R*.56],
    [cx+R*.34,cy-R*.32],[cx-R*.34,cy+R*.32],
    [cx+R*.32,cy+R*.22],[cx-R*.32,cy-R*.22],
  ];
  leds.forEach(([x,y],i)=>{
    const sz2=i<4?4.2:3.2;
    ctx.save();ctx.shadowColor='#ff1a1a';ctx.shadowBlur=12;
    ctx.fillStyle='#ff2a2a';ctx.beginPath();ctx.arc(x,y,sz2,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#ff9090';ctx.beginPath();ctx.arc(x,y,sz2*.4,0,Math.PI*2);ctx.fill();
    ctx.restore();
  });

  /* ─ small rectangular components ─ */
  [[cx+R*.38,cy],[cx-R*.38,cy],[cx,cy-R*.4],[cx,cy+R*.4]].forEach(([x,y],i)=>{
    ctx.save();ctx.fillStyle='rgba(140,0,0,.55)';ctx.strokeStyle='rgba(200,0,0,.6)';ctx.lineWidth=.8;
    const w=i%2===0?10:8,h=i%2===0?5:8;
    ctx.fillRect(x-w/2,y-h/2,w,h);ctx.strokeRect(x-w/2,y-h/2,w,h);ctx.restore();
  });

  /* ─ Bitcoin ₿ symbol ─ */
  ctx.save();
  const fz=Math.round(R*.96);
  ctx.font=`900 ${fz}px 'Arial Black',Arial,sans-serif`;
  ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillStyle='rgba(0,0,0,.88)';ctx.fillText('₿',cx+5,cy+6);
  ctx.shadowColor='#ff0000';ctx.shadowBlur=40;
  ctx.fillStyle='#880000';ctx.fillText('₿',cx,cy);
  ctx.shadowBlur=18;ctx.fillStyle='rgba(255,20,20,.22)';ctx.fillText('₿',cx,cy);
  ctx.restore();

  /* ─ center inner glow over symbol ─ */
  const cg=ctx.createRadialGradient(cx,cy,0,cx,cy,R*.28);
  cg.addColorStop(0,'rgba(80,0,0,.0)');cg.addColorStop(.6,'rgba(50,0,0,.0)');cg.addColorStop(1,'rgba(30,0,0,.15)');
  ctx.save();coinClip();ctx.fillStyle=cg;ctx.fillRect(0,0,sz,sz);ctx.restore();
}

/* ══════════════════════════════════════════════
   CANVAS CHARTS
══════════════════════════════════════════════ */
function drawArea(id,data,line,fill,H=70){
  const r=getCtx(id,H);if(!r)return;
  const{ctx,W}=r;
  ctx.clearRect(0,0,W,H);
  const mn=Math.min(...data),mx=Math.max(...data),rng=mx-mn||1;
  const pts=data.map((v,i)=>[(i/(data.length-1))*W,H-6-((v-mn)/rng)*(H-14)]);
  const path=()=>{ctx.moveTo(pts[0][0],pts[0][1]);for(let i=1;i<pts.length;i++){const m=(pts[i-1][0]+pts[i][0])/2;ctx.bezierCurveTo(m,pts[i-1][1],m,pts[i][1],pts[i][0],pts[i][1]);}};
  ctx.beginPath();path();ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();
  const g=ctx.createLinearGradient(0,0,0,H);g.addColorStop(0,fill+'55');g.addColorStop(1,fill+'00');
  ctx.fillStyle=g;ctx.fill();
  ctx.beginPath();path();ctx.strokeStyle=line;ctx.lineWidth=2;ctx.lineJoin='round';ctx.stroke();
}
function drawBars(id,data,color){
  const r=getCtx(id,70);if(!r)return;
  const{ctx,W,H}=r;ctx.clearRect(0,0,W,H);
  const mx=Math.max(...data);const bw=Math.floor(W/data.length*.55);const gap=(W-bw*data.length)/(data.length+1);
  data.forEach((v,i)=>{
    const bh=(v/mx)*(H-8),x=gap+i*(bw+gap),y=H-bh;
    const g=ctx.createLinearGradient(0,y,0,H);g.addColorStop(0,color+'ff');g.addColorStop(1,color+'88');
    ctx.fillStyle=g;ctx.beginPath();
    if(ctx.roundRect)ctx.roundRect(x,y,bw,bh,[3,3,0,0]);else ctx.rect(x,y,bw,bh);
    ctx.fill();
  });
}
function drawDonut(id,data,colors,sz=150,holeFill){
  const c=$(id);if(!c)return;
  const dpr=Math.min(window.devicePixelRatio||1,2);
  c.width=c.height=sz*dpr;
  c.style.width=sz+'px';c.style.height=sz+'px';
  const ctx=c.getContext('2d');ctx.scale(dpr,dpr);
  const cx=sz/2,cy=sz/2,r=sz*.44,inner=sz*.29;
  // gap between segments (in radians), skip if single segment
  const gap=data.length>1?0.018:0;
  const total=data.reduce((a,b)=>a+b,0);let st=-Math.PI/2;
  data.forEach((v,i)=>{
    const a=Math.max((v/total)*Math.PI*2 - gap, 0.001);
    const g=ctx.createLinearGradient(0,0,sz,sz);
    g.addColorStop(0,colors[i]);g.addColorStop(1,colors[i]+'bb');
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,st,st+a);ctx.closePath();
    ctx.fillStyle=g;ctx.fill();
    st+=a+gap;
  });
  // inner hole — use passed color or detect from card background
  const bg=holeFill||_sc.cardBg||'#ffffff';
  ctx.beginPath();ctx.arc(cx,cy,inner,0,Math.PI*2);ctx.fillStyle=bg;ctx.fill();
}
function drawPerfChart(){
  const r=getCtx('ap-perf-chart',200);if(!r)return;
  const{ctx,W,H}=r;
  const labels=_sc.perfMonths||['Feb','Mar','Apr','May','Jun','Jul'];
  const crypto=_sc.perfCrypto||[0,14,22,32,40,46];
  const stocks=_sc.perfStocks||[0,8,12,16,21,19];
  const forex=_sc.perfForex||[0,3,5,7,8,8.7];
  const re=_sc.perfRE||[0,5,9,12,14,16];
  const allPts=[...crypto,...stocks,...forex,...re];
  const mx=Math.max(...allPts)*1.08||48;
  const pad={l:6,r:6,t:10,b:22};
  ctx.strokeStyle=_sc.borderColor||'rgba(0,0,0,.06)';ctx.lineWidth=1;
  [.25,.5,.75,1].forEach(f=>{const y=pad.t+(1-f)*(H-pad.t-pad.b);ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(W-pad.r,y);ctx.stroke();});
  const mkPts=d=>d.map((v,i)=>[pad.l+(i/(d.length-1))*(W-pad.l-pad.r),pad.t+(1-v/mx)*(H-pad.t-pad.b)]);
  function line(pts,color,dash=[]){
    ctx.beginPath();ctx.setLineDash(dash);ctx.moveTo(pts[0][0],pts[0][1]);
    for(let i=1;i<pts.length;i++){const m=(pts[i-1][0]+pts[i][0])/2;ctx.bezierCurveTo(m,pts[i-1][1],m,pts[i][1],pts[i][0],pts[i][1]);}
    ctx.setLineDash([]);ctx.strokeStyle=color;ctx.lineWidth=2;ctx.lineJoin='round';ctx.stroke();
  }
  line(mkPts(crypto),'#3d8ef0');line(mkPts(stocks),'#00e676');line(mkPts(forex),'#f5a623',[5,3]);line(mkPts(re),'#9b59b6');
  ctx.fillStyle=_sc.text3Color||'rgba(90,99,128,.8)';ctx.font='9px system-ui';ctx.textAlign='center';
  labels.forEach((l,i)=>ctx.fillText(l,pad.l+(i/(labels.length-1))*(W-pad.l-pad.r),H-5));
}

/* ══════════════════════════════════════════════
   TICKER UPDATE — crypto-only
══════════════════════════════════════════════ */
function updateTicker(){
  const fmt=v=>(v>=0?'+':'')+v.toFixed(2)+'%';
  const cls=v=>'ap-tick-chg '+(v>=0?'up':'dn');
  function fmtP(v){
    if(v>=1000)return fmtN(v,0);
    if(v>=1)return v.toFixed(2);
    if(v>=0.01)return v.toFixed(4);
    return v.toFixed(6);
  }
  /* ticker prices */
  [['btc',fmtN(fx.btc.price,0)],['eth',fmtN(fx.eth.price,0)],
   ['bnb',fmtN(fx.bnb.price,0)],['sol',fmtP(fx.sol.price)],
   ['xrp',fmtP(fx.xrp.price)],['doge',fx.doge.price.toFixed(4)],
   ['ada',fx.ada.price.toFixed(4)],['trx',fx.trx.price.toFixed(4)],
   ['avax',fmtP(fx.avax.price)],['ton',fmtP(fx.ton.price)]
  ].forEach(([k,v])=>{const e=$('tk-'+k);if(e)e.textContent=v;});
  /* ticker % changes */
  [['btc',fx.btc.chg],['eth',fx.eth.chg],['bnb',fx.bnb.chg],['sol',fx.sol.chg],
   ['xrp',fx.xrp.chg],['doge',fx.doge.chg],['ada',fx.ada.chg],['trx',fx.trx.chg],
   ['avax',fx.avax.chg],['ton',fx.ton.chg]
  ].forEach(([k,c])=>{const e=$('tkc-'+k);if(e){e.textContent=fmt(c);e.className=cls(c);}});
  /* market card prices */
  if($('c-btc'))$('c-btc').textContent='$'+fmtN(fx.btc.price,0);
  if($('c-eth'))$('c-eth').textContent='$'+fmtN(fx.eth.price,0);
  if($('c-bnb'))$('c-bnb').textContent='$'+fmtN(fx.bnb.price,0);
  if($('c-sol'))$('c-sol').textContent='$'+fmtP(fx.sol.price);
  /* market card change labels */
  const setChg=(id,v,sfx)=>{const e=$(id);if(!e)return;e.innerHTML=`<i class="fas fa-caret-${v>=0?'up':'down'}"></i> ${Math.abs(v).toFixed(2)}%${sfx}`;e.className='ap-mcard-chg '+(v>=0?'up':'dn');};
  setChg('cc-btc',fx.btc.chg,' Today');
  setChg('cc-eth',fx.eth.chg,' ETH');
  setChg('cc-bnb',fx.bnb.chg,' BNB');
  setChg('cc-sol',fx.sol.chg,' SOL');
  /* analytics live numbers */
  if($('ana-btc-chg'))$('ana-btc-chg').textContent=(fx.btc.chg>=0?'+':'')+fx.btc.chg.toFixed(2)+'%';
  if($('ana-eth-price'))$('ana-eth-price').textContent='$'+fmtN(fx.eth.price,0);
  if($('ana-eth-chg'))$('ana-eth-chg').textContent=(fx.eth.chg>=0?'+':'')+fx.eth.chg.toFixed(2)+'%';
  if($('ana-bnb-price'))$('ana-bnb-price').textContent='$'+fmtN(fx.bnb.price,0);
  if($('ana-bnb-chg'))$('ana-bnb-chg').textContent=(fx.bnb.chg>=0?'+':'')+fx.bnb.chg.toFixed(2)+'%';
  if($('ana-sol-price'))$('ana-sol-price').textContent='$'+fmtP(fx.sol.price);
  if($('ana-sol-chg'))$('ana-sol-chg').textContent=(fx.sol.chg>=0?'+':'')+fx.sol.chg.toFixed(2)+'%';
}

