/* ══════════════════════════════════════════════
   SECTION SLIDESHOWS
══════════════════════════════════════════════ */
function initSlideshow(wrapId, dotsId, intervalSec) {
  var wrap = document.getElementById(wrapId);
  var dotsEl = document.getElementById(dotsId);
  if (!wrap) return;
  var layers = wrap.querySelectorAll('.slide-bg-layer');
  if (layers.length <= 1) return;
  var dots = dotsEl ? dotsEl.querySelectorAll('.slide-dot') : [];
  var cur = 0;

  function goTo(idx) {
    layers[cur].classList.remove('active');
    if (dots[cur]) dots[cur].classList.remove('active');
    cur = (idx + layers.length) % layers.length;
    layers[cur].classList.add('active');
    if (dots[cur]) dots[cur].classList.add('active');
  }

  // dot click navigation
  dots.forEach(function(dot) {
    dot.addEventListener('click', function() { goTo(parseInt(this.dataset.idx)); });
  });

  setInterval(function() { goTo(cur + 1); }, intervalSec * 1000);
}

