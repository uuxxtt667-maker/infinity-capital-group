<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Invest Smarter Across Every Market | <%= siteName %></title>
<% if(siteCustomize.seoDescription){ %><meta name="description" content="<%= siteCustomize.seoDescription %>"><% } %>
<% if(siteCustomize.seoKeywords){ %><meta name="keywords" content="<%= siteCustomize.seoKeywords %>"><% } %>
<meta property="og:title" content="Invest Smarter | <%= siteName %>">
<% if(siteCustomize.seoDescription){ %><meta property="og:description" content="<%= siteCustomize.seoDescription %>"><% } %>
<% if(siteCustomize.ogImage){ %><meta property="og:image" content="<%= siteCustomize.ogImage %>"><% } %>
<meta property="og:type" content="website">
<% if(siteCustomize.faviconUrl){ %>
<link rel="icon" type="image/x-icon" href="<%= siteCustomize.faviconUrl %>">
<link rel="shortcut icon" href="<%= siteCustomize.faviconUrl %>">
<% } %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Segoe UI',system-ui,sans-serif;background:#ffffff;color:#1e293b;overflow-x:hidden;line-height:1.6}
a{text-decoration:none;color:inherit}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:#f1f5f9}::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:3px}

/* glow blobs removed — use bg images instead */

/* ── NAV ── */
.ap-nav{position:sticky;top:0;z-index:1000;background:rgba(255,255,255,.97);border-bottom:1px solid #e2e8f0;backdrop-filter:blur(18px);box-shadow:0 1px 12px rgba(0,0,0,.06)}
.ap-nav-inner{max-width:1320px;margin:0 auto;padding:0 1.5rem;display:flex;align-items:center;height:66px;gap:1rem}
.ap-logo{display:flex;align-items:center;gap:.5rem;font-size:1.3rem;font-weight:900;color:#1e293b;letter-spacing:-.5px;margin-right:1rem;white-space:nowrap}
.ap-logo-icon{width:32px;height:32px;background:linear-gradient(135deg,#3d8ef0,#7c3aed);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.9rem}
.ap-logo span{color:#3d8ef0}
.ap-links{display:flex;gap:.1rem;list-style:none;flex:1;flex-wrap:nowrap}
.ap-links a{color:#64748b;padding:.4rem .85rem;border-radius:7px;font-size:.85rem;font-weight:500;transition:all .2s;white-space:nowrap}
.ap-links a:hover{color:#1e293b;background:rgba(0,0,0,.05)}
.ap-nav-right{display:flex;align-items:center;gap:.7rem;flex-shrink:0}
.ap-btn-in{color:#64748b;padding:.4rem .9rem;font-size:.85rem;font-weight:600;transition:color .2s;white-space:nowrap}
.ap-btn-in:hover{color:#1e293b}
.ap-btn-reg{background:linear-gradient(135deg,#3d8ef0,#2563eb);color:#fff;padding:.5rem 1.35rem;border-radius:8px;font-size:.85rem;font-weight:700;transition:all .2s;white-space:nowrap;display:inline-flex;align-items:center;gap:.4rem;box-shadow:0 4px 12px rgba(61,142,240,.3)}
.ap-btn-reg:hover{background:linear-gradient(135deg,#2a6fd6,#1d4fb8);transform:translateY(-1px);box-shadow:0 8px 24px rgba(61,142,240,.4)}
.ap-ham{display:none;background:none;border:none;color:#64748b;font-size:1.3rem;cursor:pointer;padding:.4rem;margin-left:auto}

/* ── HERO ── */
.ap-hero{position:relative;min-height:88vh;display:flex;align-items:center;overflow:hidden;padding:3rem 1.5rem 2rem;background:linear-gradient(145deg,#eef6ff 0%,#f0f7ff 35%,#f5f9ff 65%,#ffffff 100%)}
.ap-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 68% 45%,rgba(61,142,240,.1) 0%,transparent 65%),radial-gradient(ellipse 40% 50% at 20% 70%,rgba(124,58,237,.05) 0%,transparent 60%);pointer-events:none;z-index:1}
.ap-hero-inner{max-width:1320px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:center;position:relative;z-index:2}
.ap-hero-badges{display:flex;gap:.6rem;margin-bottom:1.5rem;flex-wrap:wrap}
.ap-badge{display:inline-flex;align-items:center;gap:.4rem;background:rgba(61,142,240,.08);border:1px solid rgba(61,142,240,.2);color:#3d8ef0;font-size:.72rem;font-weight:700;padding:.3rem .85rem;border-radius:20px;letter-spacing:.05em}
.ap-badge .dot{width:6px;height:6px;border-radius:50%;background:#00c853;box-shadow:0 0 6px #00c853;animation:pulse-dot 2s infinite}
.ap-hero h1{font-size:clamp(2.4rem,5vw,3.8rem);font-weight:900;line-height:1.08;letter-spacing:-.03em;margin-bottom:1rem;color:#0f172a}
.ap-hero h1 .grad{background:linear-gradient(90deg,#3d8ef0,#7c3aed);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.ap-hero-sub{font-size:1rem;color:#64748b;margin-bottom:2rem;line-height:1.7}
.ap-hero-ctas{display:flex;gap:.9rem;flex-wrap:wrap;margin-bottom:2.5rem}
.ap-btn-primary{background:linear-gradient(135deg,#3d8ef0,#2563eb);color:#fff;padding:.75rem 2rem;border-radius:10px;font-size:.95rem;font-weight:700;display:inline-flex;align-items:center;gap:.5rem;transition:all .25s;box-shadow:0 6px 20px rgba(61,142,240,.35)}
.ap-btn-primary:hover{background:linear-gradient(135deg,#2a6fd6,#1d4fb8);transform:translateY(-2px);box-shadow:0 12px 32px rgba(61,142,240,.45);color:#fff}
.ap-btn-ghost{background:rgba(255,255,255,.8);border:1.5px solid #e2e8f0;color:#475569;padding:.75rem 2rem;border-radius:10px;font-size:.95rem;font-weight:600;display:inline-flex;align-items:center;gap:.5rem;transition:all .25s;box-shadow:0 2px 8px rgba(0,0,0,.06)}
.ap-btn-ghost:hover{background:#fff;border-color:#3d8ef0;color:#3d8ef0;box-shadow:0 4px 16px rgba(61,142,240,.15)}

/* ── HERO GLOBE VISUAL ── */
.ap-hero-visual{position:relative;height:520px;display:flex;align-items:center;justify-content:center;overflow:visible}
.ap-globe-wrap{position:relative;width:440px;height:440px}
.ap-globe-glow{position:absolute;inset:-50px;background:radial-gradient(circle,rgba(61,142,240,.2) 0%,rgba(124,58,237,.1) 50%,transparent 70%);border-radius:50%;animation:globe-pulse 4s ease-in-out infinite}
#globeCanvas{position:relative;z-index:2;border-radius:50%;box-shadow:0 20px 60px rgba(61,142,240,.3)}
.ap-coin{position:absolute;z-index:3;display:flex;align-items:center;justify-content:center;border-radius:50%;font-size:1.6rem;font-weight:900;box-shadow:0 8px 28px rgba(0,0,0,.2);animation:float-coin 6s ease-in-out infinite}
.ap-coin-btc{width:60px;height:60px;background:linear-gradient(135deg,#f7931a,#e07d10);top:4%;right:14%;animation-delay:0s}
.ap-coin-eth{width:52px;height:52px;background:linear-gradient(135deg,#627eea,#8e6de0);top:20%;right:2%;animation-delay:-2s}
.ap-coin-sol{width:44px;height:44px;background:linear-gradient(135deg,#9945ff,#14f195);bottom:20%;right:6%;animation-delay:-4s;font-size:.85rem}
.ap-coin-bnb{width:40px;height:40px;background:linear-gradient(135deg,#f3ba2f,#d4a017);bottom:6%;left:10%;animation-delay:-1s;font-size:.8rem}
.ap-coin-ada{width:36px;height:36px;background:linear-gradient(135deg,#0033ad,#0066ff);top:8%;left:14%;animation-delay:-3s;font-size:.75rem}
@keyframes float-coin{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-16px) rotate(6deg)}}
@keyframes globe-pulse{0%,100%{opacity:.7;transform:scale(1)}50%{opacity:1;transform:scale(1.06)}}
@keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.3}}

/* ── ASSET CATEGORY ICONS ── */
.ap-asset-cats{display:flex;gap:1.25rem;margin-top:2rem;flex-wrap:wrap;align-items:flex-start}
.ap-asset-cat{display:flex;flex-direction:column;align-items:center;gap:.4rem;cursor:pointer;transition:transform .2s;text-decoration:none}
.ap-asset-cat:hover{transform:translateY(-3px)}
.ap-acat-icon{width:54px;height:54px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:1.35rem;border:1.5px solid #e2e8f0;background:#ffffff;box-shadow:0 2px 10px rgba(0,0,0,.08);transition:all .2s}
.ap-asset-cat:hover .ap-acat-icon{box-shadow:0 6px 20px rgba(0,0,0,.12);transform:none;border-color:transparent}
.ap-acat-lbl{font-size:.57rem;font-weight:800;letter-spacing:.1em;color:#94a3b8;text-transform:uppercase;white-space:nowrap}

/* ── TICKER ── */
.ap-ticker{background:#080d1c;border-top:1px solid rgba(255,255,255,.06);border-bottom:1px solid rgba(255,255,255,.06);overflow:hidden;height:38px;display:flex;align-items:center;position:relative;z-index:2}
.ap-ticker-track{display:flex;align-items:center;gap:2.5rem;animation:ticker 50s linear infinite;white-space:nowrap;padding:0 1rem}
.ap-ticker-track:hover{animation-play-state:paused}
.ap-tick-item{display:flex;align-items:center;gap:.5rem;font-size:.78rem}
.ap-tick-pair{color:rgba(255,255,255,.4);font-weight:600}
.ap-tick-price{color:#e2e8f0;font-weight:800;font-variant-numeric:tabular-nums}
.ap-tick-chg{font-weight:700;font-size:.75rem}
.ap-tick-chg.up{color:#00e676}.ap-tick-chg.dn{color:#ff4757}
@keyframes ticker{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* ── MARKET CARDS ── */
.ap-cards-row{max-width:1320px;margin:2.5rem auto;padding:0 1.5rem;display:grid;grid-template-columns:repeat(5,1fr);gap:1.1rem}
.ap-mcard{background:#ffffff;border:1px solid #e2e8f0;border-radius:16px;padding:1.35rem;transition:all .25s;overflow:hidden;position:relative;box-shadow:0 1px 4px rgba(0,0,0,.06)}
.ap-mcard::after{content:'';position:absolute;inset:0;border-radius:16px;opacity:0;transition:opacity .25s;pointer-events:none}
.ap-mcard:hover{transform:translateY(-4px);box-shadow:0 12px 30px rgba(0,0,0,.1)}
.ap-mcard:hover::after{opacity:1}
.ap-mcard-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
.ap-mcard-lbl{font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#94a3b8}
.ap-mcard-badge{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.25rem}
.ap-mcard-price{font-size:1.7rem;font-weight:900;color:#1e293b;margin-bottom:.25rem;font-variant-numeric:tabular-nums;line-height:1}
.ap-mcard-chg{font-size:.78rem;font-weight:700;margin-bottom:.5rem;display:flex;align-items:center;gap:.3rem}
.ap-mcard-chg.up{color:#059669}.ap-mcard-chg.dn{color:#dc2626}
.ap-mcard-sub{font-size:.65rem;color:#94a3b8;margin-bottom:.75rem}
.ap-mcard-chart{width:100%;height:70px;display:block}

/* invite card */
.ap-invite-card{background:linear-gradient(135deg,#0d1f4a,#0f2868);border:1px solid rgba(61,142,240,.22);display:flex;flex-direction:column;justify-content:center;gap:.6rem}
.ap-invite-card:hover{border-color:rgba(61,142,240,.45);box-shadow:0 20px 50px rgba(61,142,240,.2)}
.ap-invite-icon{font-size:2rem;margin-bottom:.25rem}
.ap-invite-card h4{font-size:.95rem;font-weight:800;color:#fff}
.ap-invite-card p{font-size:.75rem;color:#8a94b8;line-height:1.5}
.ap-invite-card p strong{color:#00e676;font-size:1.1rem}
.ap-invite-btn{background:#3d8ef0;color:#fff;border:none;padding:.55rem 1.2rem;border-radius:8px;font-size:.8rem;font-weight:700;cursor:pointer;font-family:inherit;transition:all .2s;margin-top:.25rem;width:fit-content}
.ap-invite-btn:hover{background:#2a6fd6}

/* ── STATS BAR ── */
.ap-stats-bar{max-width:1320px;margin:0 auto 2.5rem;padding:0 1.5rem;display:grid;grid-template-columns:repeat(5,1fr);gap:1.1rem}
.ap-stat-pill{background:#ffffff;border:1px solid #e2e8f0;border-radius:14px;padding:1.1rem 1.3rem;display:flex;align-items:center;gap:.9rem;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.ap-stat-icon{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
.ap-stat-val{font-size:1.35rem;font-weight:900;color:#1e293b;line-height:1.1;font-variant-numeric:tabular-nums}
.ap-stat-lbl{font-size:.67rem;color:#94a3b8;font-weight:600;margin-top:.1rem}

/* ── BOTTOM ROW ── */
.ap-bottom{max-width:1320px;margin:0 auto 2.5rem;padding:0 1.5rem;display:grid;grid-template-columns:1.1fr 2fr 1fr;gap:1.1rem;align-items:stretch}
.ap-panel{background:#ffffff;border:1px solid #e2e8f0;border-radius:18px;padding:1.5rem;box-shadow:0 1px 4px rgba(0,0,0,.06)}
.ap-panel h4{font-size:.9rem;font-weight:800;color:#1e293b;margin-bottom:1.1rem}

/* donut */
.ap-donut-wrap{position:relative;width:150px;height:150px;flex-shrink:0}
.ap-donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center}
.ap-donut-center .dlbl{font-size:.65rem;color:#94a3b8}
.ap-donut-center .dval{font-size:1.2rem;font-weight:900;color:#1e293b}
.ap-legend{display:flex;flex-direction:column;gap:.5rem;flex:1}
.ap-leg-item{display:flex;align-items:center;justify-content:space-between;font-size:.75rem;color:#64748b}
.ap-leg-left{display:flex;align-items:center;gap:.5rem}
.ap-leg-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.ap-leg-pct{font-weight:700;color:#1e293b}
.ap-portfolio-inner{display:flex;align-items:center;gap:1.25rem;margin-bottom:1rem}

/* performance */
.ap-perf-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:.4rem}
.ap-perf-badge{background:rgba(0,230,118,.12);color:#00e676;font-size:.7rem;font-weight:700;padding:.2rem .65rem;border-radius:20px}
.ap-perf-chart{width:100%;flex:1;min-height:200px;display:block}
.ap-perf-legend{display:flex;gap:1rem;margin-top:.75rem;flex-wrap:wrap}
.ap-perf-leg{display:flex;align-items:center;gap:.35rem;font-size:.7rem;color:#5a6380}
.ap-perf-line{width:20px;height:2px;border-radius:1px}
.ap-perf-returns{display:flex;gap:1.1rem;margin-top:.5rem}
.ap-ret-val{font-size:.82rem;font-weight:800}
.ap-ret-lbl{font-size:.64rem;color:#5a6380}

/* cta col */
.ap-cta-col{display:flex;flex-direction:column;gap:1.1rem}
.ap-cta-card{border-radius:16px;padding:1.5rem;flex:1;transition:all .25s;display:flex;flex-direction:column}
.ap-cta-inv{background:linear-gradient(145deg,#0d1f4a,#0f2868);border:1px solid rgba(61,142,240,.2)}
.ap-cta-inv:hover{border-color:rgba(61,142,240,.45);box-shadow:0 14px 40px rgba(61,142,240,.2);transform:translateY(-2px)}
.ap-cta-earn{background:linear-gradient(145deg,#0a2918,#0e3d22);border:1px solid rgba(0,230,118,.18)}
.ap-cta-earn:hover{border-color:rgba(0,230,118,.4);box-shadow:0 14px 40px rgba(0,230,118,.15);transform:translateY(-2px)}
.ap-cta-ico{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;margin-bottom:.85rem}
.ap-cta-inv .ap-cta-ico{background:rgba(61,142,240,.15);color:#6bb3ff}
.ap-cta-earn .ap-cta-ico{background:rgba(0,230,118,.12);color:#00e676}
.ap-cta-card h5{font-size:1rem;font-weight:800;margin-bottom:.3rem}
.ap-cta-inv h5{color:#fff}.ap-cta-earn h5{color:#00e676}
.ap-cta-card p{font-size:.75rem;color:#8a94b8;flex:1;line-height:1.6;margin-bottom:.85rem}
.ap-cta-link{font-size:.8rem;font-weight:700;padding:.5rem .9rem;border-radius:8px;display:inline-flex;align-items:center;gap:.35rem;transition:all .2s}
.ap-cta-inv .ap-cta-link{color:#6bb3ff;background:rgba(61,142,240,.12)}
.ap-cta-inv .ap-cta-link:hover{background:rgba(61,142,240,.22)}
.ap-cta-earn .ap-cta-link{color:#00e676;background:rgba(0,230,118,.1)}
.ap-cta-earn .ap-cta-link:hover{background:rgba(0,230,118,.18)}

/* ── FEATURES ── */
.ap-features{max-width:1320px;margin:0 auto 1.5rem;padding:0 1.5rem}
.ap-feat-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1.1rem}
.ap-feat-card{background:#ffffff;border:1px solid #e2e8f0;border-radius:16px;padding:1.35rem;transition:all .25s;cursor:pointer;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.ap-feat-card:hover{border-color:#bfdbfe;transform:translateY(-3px);box-shadow:0 10px 30px rgba(0,0,0,.08)}
.ap-feat-icon{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;margin-bottom:.9rem}
.ap-feat-card h5{font-size:.85rem;font-weight:800;color:#1e293b;margin-bottom:.3rem}
.ap-feat-card p{font-size:.72rem;color:#64748b;line-height:1.6;margin-bottom:.65rem}
.ap-feat-link{font-size:.72rem;font-weight:700;display:flex;align-items:center;gap:.25rem}

/* ── SECTION SHARED ── */
.ap-section{padding:5.5rem 1.5rem;position:relative;overflow:hidden}
.ap-section-inner{max-width:1320px;margin:0 auto;text-align:center;position:relative;z-index:2}
.ap-eyebrow{display:inline-flex;align-items:center;gap:.5rem;background:rgba(61,142,240,.08);border:1px solid rgba(61,142,240,.2);color:#3d8ef0;font-size:.68rem;font-weight:700;letter-spacing:.1em;padding:.3rem .9rem;border-radius:20px;margin-bottom:1.1rem;text-transform:uppercase}
.ap-eyebrow::before{content:'◆';font-size:.5rem;color:#3d8ef0}
.ap-section-inner h2{font-size:clamp(1.9rem,3.5vw,2.8rem);font-weight:900;color:#1e293b;margin-bottom:.85rem;line-height:1.1}
.ap-section-inner h2 .grad{background:linear-gradient(90deg,#3d8ef0,#9b59b6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.ap-section-inner > p{font-size:.95rem;color:#64748b;margin:0 auto 3rem;max-width:580px}

/* ── ABOUT ── */
.ap-about-wrap{display:grid;grid-template-columns:1fr 3fr 1fr;gap:2rem;align-items:center;margin-bottom:3rem}
.ap-about-art{display:flex;align-items:center;justify-content:center}
.ap-eth-art{width:160px;height:160px;position:relative;animation:float-coin 5s ease-in-out infinite}
.ap-btc-art{width:160px;height:160px;position:relative;animation:float-coin 5s ease-in-out infinite;animation-delay:-2.5s}
.ap-eth-gem{width:130px;height:130px;background:linear-gradient(135deg,#627eea,#8e6de0,#00d4ff);clip-path:polygon(50% 0%,100% 38%,82% 100%,18% 100%,0% 38%);filter:drop-shadow(0 0 20px rgba(98,126,234,.4));margin:auto}
.ap-btc-coin{width:130px;height:130px;background:linear-gradient(135deg,#f7931a,#ffc107,#e07d10);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:3.5rem;filter:drop-shadow(0 0 20px rgba(247,147,26,.35));margin:auto}
.ap-about-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.1rem}
.ap-about-card{background:#ffffff;border:1px solid #e2e8f0;border-radius:16px;padding:1.5rem;text-align:left;transition:all .25s;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.ap-about-card:hover{border-color:#bfdbfe;transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.08)}
.ap-about-card i{font-size:1.6rem;margin-bottom:.85rem;display:block}
.ap-about-card h4{font-size:.9rem;font-weight:800;color:#1e293b;margin-bottom:.4rem}
.ap-about-card p{font-size:.75rem;color:#64748b;line-height:1.6}

/* ── HOW IT WORKS ── */
.ap-how-dark{background:#f8fafc}
.ap-steps-row{display:flex;align-items:flex-start;justify-content:center;gap:.75rem;flex-wrap:wrap}
.ap-step{background:#ffffff;border:1px solid #e2e8f0;border-radius:18px;padding:1.75rem 1.25rem;width:200px;text-align:center;transition:all .25s;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.ap-step:hover{border-color:#bfdbfe;transform:translateY(-4px);box-shadow:0 10px 30px rgba(0,0,0,.08)}
.ap-step-num{font-size:.65rem;font-weight:800;letter-spacing:.15em;color:#3d8ef0;margin-bottom:.65rem}
.ap-step-icon{width:58px;height:58px;border-radius:18px;background:rgba(61,142,240,.1);border:1px solid rgba(61,142,240,.18);display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#3d8ef0;margin:0 auto .85rem}
.ap-step h4{font-size:.88rem;font-weight:800;color:#1e293b;margin-bottom:.4rem}
.ap-step p{font-size:.72rem;color:#64748b;line-height:1.6}
.ap-step-arrow{color:#cbd5e1;font-size:1.2rem;padding-top:3rem}

/* ── ANALYTICS ── */
.ap-ana-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1.1rem;text-align:left}
.ap-ana-card{background:#ffffff;border:1px solid #e2e8f0;border-radius:16px;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.ap-ana-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:.85rem}
.ap-ana-head span:first-child{font-size:.8rem;font-weight:700;color:#1e293b}
.bx-green{background:rgba(0,230,118,.12);color:#00e676;font-size:.66rem;font-weight:700;padding:.18rem .6rem;border-radius:20px}
.bx-blue{background:rgba(61,142,240,.12);color:#6bb3ff;font-size:.66rem;font-weight:700;padding:.18rem .6rem;border-radius:20px}
.bx-gold{background:rgba(245,166,35,.12);color:#f5a623;font-size:.66rem;font-weight:700;padding:.18rem .6rem;border-radius:20px}
.ap-ana-chart{height:60px;margin-bottom:.75rem}
.ap-ana-chart canvas{width:100%!important;height:60px;display:block}
.ap-ana-stats div{display:flex;justify-content:space-between;font-size:.72rem;color:#94a3b8;margin-bottom:.2rem}
.ap-ana-stats strong{font-size:.72rem}
/* upgrade card */
.ap-upgrade-card{background:linear-gradient(145deg,#fffbeb,#fef3c7);border:1px solid rgba(245,166,35,.35);display:flex;flex-direction:column;justify-content:space-between}
.ap-upgrade-card .ap-ana-head span:first-child{color:#92400e}
.up-icon{font-size:2rem;margin-bottom:.5rem}
.up-title{font-size:.9rem;font-weight:800;color:#92400e;margin-bottom:.35rem}
.up-desc{font-size:.72rem;color:#b45309;line-height:1.6;margin-bottom:1rem;flex:1}
.up-btn{background:linear-gradient(90deg,#f5a623,#e09418);color:#000;border:none;padding:.55rem 1rem;border-radius:8px;font-size:.78rem;font-weight:800;cursor:pointer;font-family:inherit;transition:all .2s;width:100%}
.up-btn:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(245,166,35,.3)}

/* ── PORTFOLIO ── */
.ap-port-grid{display:grid;grid-template-columns:auto 1fr auto;gap:2.5rem;align-items:start;max-width:1100px;margin:0 auto;text-align:left}
.ap-port-donut-wrap{position:relative;width:220px;height:220px;flex-shrink:0}
.ap-port-donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.ap-port-allocs{display:flex;flex-direction:column;gap:.9rem;min-width:220px}
.ap-port-row{display:flex;align-items:center;gap:.65rem}
.ap-port-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.ap-port-name{font-size:.78rem;color:#8a94b8;width:110px;flex-shrink:0}
.ap-port-bar-bg{flex:1;height:6px;background:rgba(0,0,0,.1);border-radius:3px;overflow:hidden}
.ap-port-bar{height:100%;border-radius:3px}
.ap-port-pct{font-size:.75rem;font-weight:700;width:30px;text-align:right}
.ap-port-usd{font-size:.7rem;color:#5a6380;width:44px;text-align:right}
.ap-port-right{display:flex;flex-direction:column;gap:1.1rem}
.ap-holdings-card,.ap-growth-card{background:#ffffff;border:1px solid #e2e8f0;border-radius:14px;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.ap-holdings-card h5,.ap-growth-card h5{font-size:.8rem;font-weight:800;color:#1e293b;margin-bottom:.85rem}
.ap-holding-row{display:flex;align-items:center;justify-content:space-between;font-size:.75rem;padding:.35rem 0;border-bottom:1px solid #f1f5f9}
.ap-holding-row:last-child{border:none}
.ap-holding-left{display:flex;align-items:center;gap:.5rem;color:#1e293b}
.ap-holding-dot{width:8px;height:8px;border-radius:50%}
.ap-holding-pct{color:#94a3b8}
.ap-holding-chg{font-weight:700}
.ap-growth-num{font-size:1.8rem;font-weight:900;color:#00e676}
.ap-growth-lbl{font-size:.7rem;color:#5a6380;margin-top:.1rem}
.ap-growth-chart{width:100%;height:70px;margin-top:.85rem}
.ap-port-ctas{display:flex;justify-content:center;gap:1rem;flex-wrap:wrap;margin-top:2rem}

/* ── CONTACT ── */
.ap-contact-grid{display:grid;grid-template-columns:1fr 1.5fr 1fr;gap:2rem;align-items:start;text-align:left;max-width:1100px;margin:0 auto}
.ap-contact-list{display:flex;flex-direction:column;gap:1.1rem}
.ap-ci{display:flex;gap:.9rem;align-items:flex-start}
.ap-ci-icon{width:42px;height:42px;border-radius:12px;background:rgba(61,142,240,.1);border:1px solid rgba(61,142,240,.18);color:#6bb3ff;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
.ap-ci h5{font-size:.82rem;font-weight:800;color:#1e293b;margin-bottom:.1rem}
.ap-ci p{font-size:.75rem;color:#6bb3ff;margin:0}
.ap-ci span{font-size:.68rem;color:#5a6380}
.ap-contact-form-wrap{background:#ffffff;border:1px solid #e2e8f0;border-radius:18px;padding:1.75rem;box-shadow:0 1px 4px rgba(0,0,0,.06)}
.ap-contact-form-wrap h4{font-size:1rem;font-weight:800;color:#1e293b;margin-bottom:1.25rem}
.cf-group{margin-bottom:.85rem}
.cf-group label{display:block;font-size:.72rem;font-weight:700;color:#64748b;margin-bottom:.3rem}
.cf-group input,.cf-group select,.cf-group textarea{width:100%;background:#f8fafc;border:1px solid #e2e8f0;border-radius:9px;padding:.6rem .85rem;color:#1e293b;font-size:.84rem;outline:none;transition:border-color .2s;font-family:inherit;box-sizing:border-box}
.cf-group input:focus,.cf-group select:focus,.cf-group textarea:focus{border-color:#3d8ef0;background:#fff}
.cf-group textarea{resize:vertical}
.cf-row{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}
.cf-btn{width:100%;background:#3d8ef0;color:#fff;border:none;padding:.75rem;border-radius:9px;font-size:.9rem;font-weight:700;cursor:pointer;font-family:inherit;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:.5rem}
.cf-btn:hover{background:#2a6fd6;transform:translateY(-1px)}
.ap-contact-art{display:flex;align-items:center;justify-content:center}
.ap-headphones-art{width:200px;height:200px;background:radial-gradient(circle,rgba(61,142,240,.15),transparent 70%);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:7rem;animation:float-coin 5s ease-in-out infinite;filter:drop-shadow(0 0 30px rgba(61,142,240,.3))}

/* ── FOOTER ── */
.ap-footer{background:#1e293b;border-top:1px solid #334155;padding:2.5rem 1.5rem 1.5rem}
.ap-footer-inner{max-width:1320px;margin:0 auto}
.ap-footer-top{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;margin-bottom:1.75rem}
.ap-footer-logo{font-size:1.3rem;font-weight:900;color:#fff}
.ap-footer-logo span{color:#3d8ef0}
.ap-footer-links{display:flex;gap:1.5rem;flex-wrap:wrap}
.ap-footer-links a{font-size:.8rem;color:#5a6380;transition:color .2s}
.ap-footer-links a:hover{color:#8a94b8}
.ap-footer-socials{display:flex;gap:.6rem}
.ap-social-btn{width:36px;height:36px;border-radius:9px;background:#0c0e1a;border:1px solid #1a1e30;display:flex;align-items:center;justify-content:center;color:#5a6380;font-size:.85rem;transition:all .2s}
.ap-social-btn:hover{color:#fff;border-color:#263050;background:#111420}
.ap-footer-bottom{border-top:1px solid #1a1e30;padding-top:1.25rem;text-align:center;font-size:.75rem;color:#3d4560}

/* ── TRUST STRIP ── */
.ap-trust{display:flex;align-items:center;justify-content:center;gap:3rem;padding:1.4rem 1.5rem;background:#f8fafc;border-top:1px solid #e2e8f0;flex-wrap:wrap}
.ap-trust-item{display:flex;align-items:center;gap:.55rem;font-size:.8rem;color:#94a3b8}

/* ── ANIMATIONS ── */
@keyframes fade-up{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
@keyframes fade-in{from{opacity:0}to{opacity:1}}
@keyframes slide-right{from{opacity:0;transform:translateX(-30px)}to{opacity:1;transform:translateX(0)}}
.anim-up{animation:fade-up .7s ease both}
.anim-in{animation:fade-in .8s ease both}
[data-aos]{opacity:0;transition:opacity .6s ease,transform .6s ease}
[data-aos="fade-up"]{transform:translateY(40px)}
[data-aos="fade-right"]{transform:translateX(-40px)}
[data-aos="fade-left"]{transform:translateX(40px)}
[data-aos].aos-animate{opacity:1;transform:none}

/* ── SECTION SLIDESHOWS ── */
.slide-bg-wrap{position:absolute;inset:0;z-index:0;overflow:hidden;pointer-events:none}
.slide-bg-layer{position:absolute;inset:0;background-size:cover;background-position:center;background-repeat:no-repeat;transition:opacity 1.6s ease;opacity:0}
.slide-bg-layer.active{opacity:1}
/* bottom banner */
.ap-bottom-banner{position:relative;overflow:hidden;min-height:340px;display:flex;align-items:center;justify-content:center;text-align:center}
.ap-bottom-banner-content{position:relative;z-index:2;max-width:700px;padding:3rem 2rem}
.ap-bottom-banner h2{font-size:clamp(1.6rem,3.5vw,2.6rem);font-weight:900;color:#fff;margin-bottom:.85rem;line-height:1.15;text-shadow:0 2px 12px rgba(0,0,0,.5)}
.ap-bottom-banner p{font-size:1rem;color:rgba(255,255,255,.85);margin-bottom:2rem;line-height:1.7;text-shadow:0 1px 6px rgba(0,0,0,.4)}
.ap-bottom-banner-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
.ap-bb-btn-primary{background:linear-gradient(135deg,#3d8ef0,#2563eb);color:#fff;padding:.75rem 2rem;border-radius:10px;font-size:.95rem;font-weight:700;display:inline-flex;align-items:center;gap:.5rem;transition:all .25s;box-shadow:0 6px 20px rgba(0,0,0,.3)}
.ap-bb-btn-primary:hover{transform:translateY(-2px);box-shadow:0 12px 32px rgba(0,0,0,.4);color:#fff}
.ap-bb-btn-ghost{background:rgba(255,255,255,.15);border:2px solid rgba(255,255,255,.5);color:#fff;padding:.75rem 2rem;border-radius:10px;font-size:.95rem;font-weight:700;display:inline-flex;align-items:center;gap:.5rem;transition:all .25s;backdrop-filter:blur(4px)}
.ap-bb-btn-ghost:hover{background:rgba(255,255,255,.25);border-color:#fff;color:#fff}
/* slide indicators */
.slide-dots{position:absolute;bottom:14px;left:50%;transform:translateX(-50%);display:flex;gap:.4rem;z-index:3}
.slide-dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.4);cursor:pointer;transition:all .3s}
.slide-dot.active{background:#fff;transform:scale(1.25)}

/* ── RE BUILDINGS ── */
.re-buildings{display:flex;align-items:flex-end;gap:5px;height:70px;padding-top:6px}
.re-building{border-radius:3px 3px 0 0;display:flex;flex-direction:column}
.re-windows{display:grid;grid-template-columns:1fr 1fr;gap:2px;padding:4px 3px;flex:1}
.re-win{background:rgba(255,255,255,.3);border-radius:1px;width:5px;height:4px}

/* ── RESPONSIVE ── */
@media(max-width:1200px){
  .ap-cards-row{grid-template-columns:repeat(3,1fr)}.ap-stats-bar{grid-template-columns:repeat(3,1fr)}
  .ap-ana-grid{grid-template-columns:repeat(3,1fr)}.ap-feat-grid{grid-template-columns:repeat(3,1fr)}
  .ap-about-wrap{grid-template-columns:1fr}.ap-about-art{display:none}
  .ap-port-grid{grid-template-columns:auto 1fr}.ap-port-right{grid-column:1/-1}
  .ap-contact-grid{grid-template-columns:1fr 1.5fr}.ap-contact-art{display:none}
}
@media(max-width:900px){
  .ap-hero-inner{grid-template-columns:1fr}.ap-hero-visual{display:none}
  .ap-bottom{grid-template-columns:1fr}.ap-feat-grid{grid-template-columns:repeat(2,1fr)}
  .ap-ana-grid{grid-template-columns:repeat(2,1fr)}.ap-about-grid{grid-template-columns:repeat(2,1fr)}
  .ap-ham{display:block}.ap-links{display:none;flex-direction:column;position:fixed;top:66px;left:0;right:0;background:rgba(255,255,255,.98);border-bottom:1px solid #e2e8f0;padding:1rem;z-index:999;box-shadow:0 8px 24px rgba(0,0,0,.1)}
  .ap-links.open{display:flex}.ap-nav-right{display:none}.ap-nav-right.open{display:flex!important;flex-direction:column;gap:.5rem;padding:0 1rem 1rem;position:fixed;top:auto;left:0;right:0;background:rgba(255,255,255,.98);z-index:998;border-bottom:1px solid #e2e8f0}
  .ap-port-grid{grid-template-columns:1fr;text-align:center}
  .ap-port-allocs{align-items:center}.ap-port-row{width:100%;max-width:300px}
}
@media(max-width:600px){
  .ap-cards-row{grid-template-columns:1fr 1fr}.ap-stats-bar{grid-template-columns:1fr 1fr}
  .ap-feat-grid{grid-template-columns:1fr 1fr}.ap-about-grid{grid-template-columns:1fr}
  .ap-ana-grid{grid-template-columns:1fr}.ap-contact-grid{grid-template-columns:1fr}
  .ap-steps-row{flex-direction:column;align-items:center}.ap-step-arrow{display:none}
}
@media(max-width:400px){.ap-cards-row{grid-template-columns:1fr}.ap-stats-bar{grid-template-columns:1fr}.ap-feat-grid{grid-template-columns:1fr}}

/* ── HERO PARTNERS BAND ── */
.ap-hpartners{position:relative;z-index:2;background:rgba(6,10,25,.7);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-top:1px solid rgba(255,255,255,.07);border-bottom:1px solid rgba(255,255,255,.07);padding:.95rem 1.5rem}
.ap-hpartners-in{max-width:1320px;margin:0 auto;display:flex;align-items:center;gap:2.5rem;flex-wrap:wrap;justify-content:center}
.ap-hpartners-lbl{font-size:.62rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.32);white-space:nowrap;flex-shrink:0;padding-right:2rem;border-right:1px solid rgba(255,255,255,.1)}
.ap-hpartner{display:flex;align-items:center;gap:.55rem;opacity:.6;transition:opacity .25s,transform .2s;text-decoration:none}
.ap-hpartner:hover{opacity:1;transform:translateY(-2px)}
.ap-hpartner-name{font-weight:900;font-size:.9rem;letter-spacing:.03em;white-space:nowrap}
@media(max-width:900px){.ap-hpartners-in{gap:1.75rem}.ap-hpartners-lbl{border-right:none;padding-right:0;border-bottom:1px solid rgba(255,255,255,.1);padding-bottom:.65rem;width:100%;text-align:center}}
@media(max-width:500px){.ap-hpartner-name{display:none}}
</style>
<% if (typeof siteCustomize !== 'undefined') { var sc = siteCustomize; var _pageBg = sc.colorBgHome || sc.colorBg; %>
<% if (sc.fontUrl) { %><link rel="stylesheet" href="<%- sc.fontUrl %>"><% } %>
<style>
  /* ══ ADMIN CUSTOMIZER OVERRIDES ══ */

  /* ── Typography ── */
  body {
    font-family: <%- sc.fontFamily %>;
    font-size: <%- sc.fontSizeBase %>;
    background: <%- _pageBg %>;
    color: <%- sc.colorText %>;
  }

  /* ── Background image (home page) ── */
  <% if (sc.bgHome) { %>
  body {
    background-image: url('<%- sc.bgHome %>') !important;
    background-size: cover !important;
    background-position: center top !important;
    background-attachment: fixed !important;
  }
  <% if (parseFloat(sc.bgOverlayHome) > 0) { %>
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,<%- sc.bgOverlayHome %>);
    z-index: 0;
    pointer-events: none;
  }
  .ap-nav, .ap-ticker, .ap-footer { position: relative; z-index: 1; }
  <% } %>
  <% } %>

  /* ── Page-level section backgrounds ── */
  .ap-hero {
    background: linear-gradient(145deg,
      <%- _pageBg %> 0%,
      <%- sc.colorBg2 %> 35%,
      <%- sc.colorBg2 %> 65%,
      <%- _pageBg %> 100%) !important;
  }
  .ap-hero::before {
    background: radial-gradient(ellipse 70% 60% at 68% 45%, <%- sc.colorPrimary %>19 0%, transparent 65%),
                radial-gradient(ellipse 40% 50% at 20% 70%, <%- sc.colorPurple %>0c 0%, transparent 60%) !important;
  }
  /* alternating section backgrounds */
  .ap-how-dark,
  .ap-section[style*="background:#f8fafc"],
  .ap-section[style*="background: #f8fafc"] {
    background: <%- sc.colorBg2 %> !important;
  }
  .ap-trust { background: <%- sc.colorBg2 %> !important; border-color: <%- sc.colorBorder %>; }
  /* ticker & footer */
  .ap-ticker { background: <%- sc.colorText %>; }
  .ap-footer { background: <%- sc.colorText %>; border-color: <%- sc.colorText2 %>66; }
  .ap-footer-bottom { color: <%- sc.colorText3 %>; border-color: <%- sc.colorText2 %>33; }
  .ap-footer-links a { color: <%- sc.colorText3 %>; }
  .ap-social-btn { background: <%- sc.colorBg %>22; border-color: <%- sc.colorBg %>33; color: <%- sc.colorText3 %>; }
  /* nav */
  .ap-nav { background: <%- sc.colorBg %>f7 !important; border-color: <%- sc.colorBorder %>; }
  .ap-logo { color: <%- sc.colorText %>; }
  .ap-links a { color: <%- sc.colorText2 %>; }
  .ap-links a:hover { color: <%- sc.colorText %>; background: <%- sc.colorBg2 %>; }

  /* ── Logo & Branding ── */
  .ap-logo span, .ap-footer-logo span { color: <%- sc.colorPrimary %>; }
  .ap-logo-icon { background: linear-gradient(135deg,<%- sc.colorPrimary %>,<%- sc.colorPurple %>); }

  /* ── Buttons ── */
  .ap-btn-reg, .ap-btn-in { color: <%- sc.colorText2 %>; }
  .ap-btn-reg {
    background: linear-gradient(135deg,<%- sc.colorPrimary %>,<%- sc.colorPrimary %>cc) !important;
    color: #fff !important;
    box-shadow: 0 4px 12px <%- sc.colorPrimary %>4d;
  }
  .ap-btn-reg:hover {
    background: linear-gradient(135deg,<%- sc.colorPrimary %>cc,<%- sc.colorPrimary %>99) !important;
    box-shadow: 0 8px 24px <%- sc.colorPrimary %>66;
  }
  .ap-btn-primary {
    background: linear-gradient(135deg,<%- sc.colorPrimary %>,<%- sc.colorPrimary %>cc) !important;
    box-shadow: 0 6px 20px <%- sc.colorPrimary %>59;
  }
  .ap-btn-primary:hover {
    background: linear-gradient(135deg,<%- sc.colorPrimary %>cc,<%- sc.colorPrimary %>99) !important;
    box-shadow: 0 12px 32px <%- sc.colorPrimary %>73;
    color: #fff;
  }
  .ap-btn-ghost:hover { border-color: <%- sc.colorPrimary %>; color: <%- sc.colorPrimary %>; }
  .cf-btn { background: <%- sc.colorPrimary %>; }
  .cf-btn:hover { background: <%- sc.colorPrimary %>cc; }
  .ap-invite-btn { background: <%- sc.colorPrimary %>; }
  .ap-invite-btn:hover { background: <%- sc.colorPrimary %>cc; }
  .up-btn { background: linear-gradient(90deg,<%- sc.colorGold %>,<%- sc.colorGold %>cc); }

  /* ── Badges / chips ── */
  .ap-eyebrow { background: <%- sc.colorPrimary %>14; color: <%- sc.colorPrimary %>; border-color: <%- sc.colorPrimary %>33; }
  .ap-eyebrow::before { color: <%- sc.colorPrimary %>; }
  .ap-badge { background: <%- sc.colorPrimary %>14; border-color: <%- sc.colorPrimary %>33; color: <%- sc.colorPrimary %>; }
  .ap-step-icon { background: <%- sc.colorPrimary %>1a; border-color: <%- sc.colorPrimary %>2e; color: <%- sc.colorPrimary %>; }
  .ap-step-num { color: <%- sc.colorPrimary %>; }

  /* ── Gradient text ── */
  .ap-hero h1 .grad,
  .ap-section-inner h2 .grad {
    background: linear-gradient(90deg,<%- sc.colorPrimary %>,<%- sc.colorPurple %>) !important;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Cards / surfaces ── */
  .ap-mcard, .ap-stat-pill, .ap-panel, .ap-about-card, .ap-feat-card,
  .ap-step, .ap-holdings-card, .ap-growth-card, .ap-contact-form-wrap, .ap-ana-card {
    background: <%- sc.colorCard %>;
    border-color: <%- sc.colorBorder %>;
  }
  .ap-feat-card:hover { border-color: <%- sc.colorPrimary %>40; }
  .ap-ci-icon { background: <%- sc.colorPrimary %>1a; color: <%- sc.colorPrimary %>cc; border-color: <%- sc.colorPrimary %>2e; }
  .ap-perf-badge { background: <%- sc.colorGreen %>1f; color: <%- sc.colorGreen %>; }

  /* ── Text — full override with !important so customizer always wins ── */
  /* headings */
  .ap-hero h1                               { color: <%- sc.colorText %> !important; }
  .ap-section-inner h2                      { color: <%- sc.colorText %> !important; }
  .ap-about-card h4, .ap-feat-card h5,
  .ap-step h4, .ap-panel h4,
  .ap-holdings-card h5, .ap-growth-card h5,
  .ap-ana-head span:first-child,
  .ap-mcard-price, .ap-stat-val,
  .ap-contact-form-wrap h4                  { color: <%- sc.colorText %> !important; }
  /* body / secondary text */
  .ap-hero-sub                              { color: <%- sc.colorText2 %> !important; }
  .ap-about-card p, .ap-feat-card p,
  .ap-step p, .ap-section-inner > p,
  .ap-mcard-sub, .ap-stat-lbl,
  .ap-trust-item                            { color: <%- sc.colorText2 %> !important; }
  /* card & eyebrow labels */
  .ap-mcard-lbl, .ap-acat-lbl              { color: <%- sc.colorText3 %> !important; }
  .ap-mcard-chg.up { color: <%- sc.colorGreen %> !important; }
  .ap-mcard-chg.dn { color: <%- sc.colorRed %>  !important; }

  /* ── Form inputs ── */
  .cf-group input, .cf-group select, .cf-group textarea {
    background: <%- sc.colorBg2 %>;
    border-color: <%- sc.colorBorder %>;
    color: <%- sc.colorText %>;
  }
  .cf-group input:focus, .cf-group select:focus, .cf-group textarea:focus {
    border-color: <%- sc.colorPrimary %>;
    background: <%- sc.colorCard %>;
  }
  .cf-group label { color: <%- sc.colorText2 %>; }

