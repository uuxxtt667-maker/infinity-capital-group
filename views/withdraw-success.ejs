<% pageTitle = 'Withdrawal Submitted' %>
<%- include('partials/head') %>
<%- include('partials/nav') %>

<style>
.ws-outer {
  min-height: calc(100vh - 68px);
  display: flex; align-items: center; justify-content: center;
  padding: 2rem 1rem; position: relative; z-index: 1;
}
.ws-card {
  width: 100%; max-width: 560px;
  background: var(--card); border: 1px solid var(--border);
  border-radius: 20px; overflow: hidden;
  position: relative; z-index: 1;
  box-shadow: 0 20px 60px rgba(0,0,0,.18);
}
.ws-header {
  background: linear-gradient(135deg, rgba(5,150,105,.15), rgba(0,180,100,.07));
  border-bottom: 1px solid rgba(5,150,105,.2);
  padding: 2rem 2rem 1.5rem;
  text-align: center;
}
.ws-check {
  width: 72px; height: 72px; border-radius: 50%;
  background: linear-gradient(135deg, rgba(5,150,105,.2), rgba(0,180,100,.1));
  border: 2px solid rgba(5,150,105,.35);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.8rem; color: #059669; margin: 0 auto 1rem;
}
.ws-title { font-size: 1.3rem; font-weight: 800; color: var(--text); margin-bottom: .3rem; }
.ws-sub   { font-size: .84rem; color: var(--text3); line-height: 1.55; }
.ws-body  { padding: 1.75rem 2rem; }
.ws-row {
  display: flex; align-items: flex-start; justify-content: space-between;
  padding: .9rem 0; border-bottom: 1px solid var(--border); gap: 1rem;
}
.ws-row:last-child { border-bottom: none; }
.ws-lbl { font-size: .75rem; font-weight: 700; color: var(--text3); text-transform: uppercase; letter-spacing: .06em; }
.ws-val { font-size: .9rem; font-weight: 700; color: var(--text); text-align: right; word-break: break-all; max-width: 65%; }
.ws-footer { padding: 1.25rem 2rem 1.75rem; border-top: 1px solid var(--border); display: flex; gap: .75rem; flex-wrap: wrap; }
.ws-status {
  display: inline-flex; align-items: center; gap: .4rem;
  background: rgba(245,166,35,.12); border: 1px solid rgba(245,166,35,.3);
  color: #f5a623; font-size: .75rem; font-weight: 700; padding: .3rem .75rem;
  border-radius: 20px; letter-spacing: .04em;
}
.ws-ref { font-size: .72rem; font-family: monospace; color: var(--text3); }
</style>

<div class="ws-outer">
  <div class="ws-card">
    <div class="ws-header">
      <div class="ws-check"><i class="fas fa-check"></i></div>
      <div class="ws-title">Withdrawal Submitted!</div>
      <div class="ws-sub">
        Your request has been received and is pending admin approval.<br>
        Processing usually takes <strong style="color:var(--text)">up to 24 hours</strong>.
      </div>
    </div>

    <div class="ws-body">
      <!-- Status badge -->
      <div style="margin-bottom:1.25rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;">
        <span class="ws-status"><i class="fas fa-clock"></i> PENDING REVIEW</span>
        <span class="ws-ref">Ref: #<%= wd.refId %></span>
      </div>

      <!-- Details table -->
      <div>
        <div class="ws-row">
          <div class="ws-lbl"><i class="fas fa-dollar-sign" style="margin-right:.3rem"></i>Amount</div>
          <div class="ws-val" style="color:var(--gold);font-size:1.1rem;">$<%= wd.amount.toFixed(2) %></div>
        </div>
        <div class="ws-row">
          <div class="ws-lbl"><i class="fas fa-network-wired" style="margin-right:.3rem"></i>Network</div>
          <div class="ws-val"><%= wd.networkLabel %></div>
        </div>
        <div class="ws-row">
          <div class="ws-lbl"><i class="fas fa-wallet" style="margin-right:.3rem"></i>Wallet Address</div>
          <div class="ws-val" style="font-family:monospace;font-size:.82rem;color:var(--text2)"><%= wd.wallet %></div>
        </div>
        <div class="ws-row">
          <div class="ws-lbl"><i class="fas fa-calendar-alt" style="margin-right:.3rem"></i>Submitted</div>
          <div class="ws-val"><%= new Date(wd.submittedAt).toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></div>
        </div>
        <div class="ws-row">
          <div class="ws-lbl"><i class="fas fa-coins" style="margin-right:.3rem"></i>Asset</div>
          <div class="ws-val">USDT (<%= wd.networkStd %>)</div>
        </div>
      </div>

      <!-- Info box -->
      <div style="background:rgba(61,142,240,.06);border:1px solid rgba(61,142,240,.18);border-radius:10px;padding:.85rem 1rem;margin-top:1.25rem;font-size:.8rem;color:var(--text2);line-height:1.6;">
        <i class="fas fa-info-circle" style="color:var(--blue);margin-right:.35rem"></i>
        You will be notified once your withdrawal is processed. Check your <strong>Transactions</strong> page for live status updates.
        If you have any issues, contact support.
      </div>
    </div>

    <div class="ws-footer">
      <a href="/transactions" class="btn btn-primary" style="flex:1;text-align:center;">
        <i class="fas fa-exchange-alt"></i> View Transactions
      </a>
      <a href="/withdraw" class="btn btn-outline" style="flex:1;text-align:center;">
        <i class="fas fa-minus-circle"></i> New Withdrawal
      </a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
