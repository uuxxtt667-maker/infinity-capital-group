<% pageTitle = 'Forgot Password' %>
<%- include('partials/head') %>
<%- include('partials/nav') %>

<style>
.fp-outer {
  min-height: calc(100vh - 68px);
  display: flex; align-items: center; justify-content: center;
  padding: 2rem 1rem;
  position: relative; z-index: 1;
}
.fp-card {
  width: 100%; max-width: 460px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 2.75rem 2.5rem 2.25rem;
  position: relative; z-index: 1;
}
.fp-icon {
  width: 64px; height: 64px; border-radius: 50%;
  background: linear-gradient(135deg, rgba(245,166,35,.18), rgba(245,166,35,.05));
  border: 2px solid rgba(245,166,35,.35);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.6rem; color: var(--gold);
  margin: 0 auto 1.4rem;
}
.fp-title { font-size: 1.35rem; font-weight: 800; color: var(--text); text-align: center; margin-bottom: .4rem; }
.fp-sub   { font-size: .84rem; color: var(--text3); text-align: center; margin-bottom: 2rem; line-height: 1.55; }
.fp-label { font-size: .75rem; font-weight: 700; color: var(--text2); margin-bottom: .45rem; display: block; }
.fp-wrap  { position: relative; margin-bottom: 1.5rem; }
.fp-icon2 { position: absolute; left: .9rem; top: 50%; transform: translateY(-50%); color: var(--text3); font-size: .85rem; }
.fp-input {
  width: 100%; padding: .72rem 1rem .72rem 2.4rem;
  border: 1.5px solid var(--border); border-radius: 10px;
  background: var(--bg2); color: var(--text); font-size: .9rem;
  outline: none; transition: border-color .2s, box-shadow .2s;
  box-sizing: border-box;
}
.fp-input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-light); }
.fp-input::placeholder { color: var(--text3); }

.fp-btn {
  width: 100%; padding: .82rem;
  border: none; border-radius: 11px;
  background: linear-gradient(135deg, var(--gold), var(--gold2));
  color: #000; font-size: .95rem; font-weight: 800;
  cursor: pointer; transition: transform .15s, box-shadow .15s;
  margin-bottom: 1.1rem;
}
.fp-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px var(--gold-light); }
.fp-back { text-align: center; font-size: .82rem; color: var(--text3); }
.fp-back a { color: var(--gold); font-weight: 700; text-decoration: none; }
</style>

<div class="fp-outer">
  <div class="fp-card">
    <div class="fp-icon"><i class="fas fa-key"></i></div>
    <div class="fp-title">Forgot Password?</div>
    <div class="fp-sub">
      Enter the email address linked to your account.<br>
      We'll send you a 6-digit reset code.
    </div>

    <form method="POST" action="/forgot-password">
      <input type="hidden" name="_csrf" value="<%= csrf %>">

      <label class="fp-label" for="fp-email">Email Address</label>
      <div class="fp-wrap">
        <i class="fas fa-envelope fp-icon2"></i>
        <input type="email" id="fp-email" name="email" class="fp-input"
          placeholder="Enter your email address" required autofocus autocomplete="email">
      </div>

      <button type="submit" class="fp-btn">
        <i class="fas fa-paper-plane" style="margin-right:.4rem"></i>Send Reset Code
      </button>
    </form>

    <div class="fp-back">
      Remember your password? <a href="/login">Sign in &rarr;</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
