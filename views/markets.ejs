/* Build pair → coin lookup + seed sparkline history */
var pairMap = {};
CRYPTO.forEach(function(c) {
  c.history = makeHist(c.price);
  pairMap[c.pair] = c;
});

/* ═══════════════════════════════════════════
   SPARKLINE CANVAS
═══════════════════════════════════════════ */
function drawSpark(canvas, data, color) {
  if (!canvas) return;
  var dpr = window.devicePixelRatio || 1;
  var W = 90, H = 28;
  canvas.width  = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  var ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);
  ctx.clearRect(0, 0, W, H);
  var mn = Math.min.apply(null, data), mx = Math.max.apply(null, data), rng = mx - mn || 1;
  var pts = data.map(function(v, i) {
    return [(i / (data.length - 1)) * W, H - 4 - ((v - mn) / rng) * (H - 8)];
  });
  ctx.beginPath();
  ctx.moveTo(pts[0][0], pts[0][1]);
  for (var i = 1; i < pts.length; i++) {
    var mx2 = (pts[i-1][0] + pts[i][0]) / 2;
    ctx.bezierCurveTo(mx2, pts[i-1][1], mx2, pts[i][1], pts[i][0], pts[i][1]);
  }
  ctx.strokeStyle = color;
  ctx.lineWidth = 1.8;
  ctx.lineJoin = 'round';
  ctx.stroke();
}

/* ═══════════════════════════════════════════
   FORMAT HELPERS
═══════════════════════════════════════════ */
function fmtN(v, dec) {
  dec = dec === undefined ? 2 : dec;
  return v.toLocaleString('en-US', {minimumFractionDigits:dec, maximumFractionDigits:dec});
}
function fmtPrice(p) {
  if (p >= 10000) return '$' + fmtN(p, 0);
  if (p >= 1000)  return '$' + fmtN(p, 2);
  if (p >= 1)     return '$' + fmtN(p, 3);
  if (p >= 0.01)  return '$' + p.toFixed(4);
  if (p >= 0.0001) return '$' + p.toFixed(6);
  return '$' + p.toFixed(8);
}
function fmtChg(c) {
  var up = c >= 0;
  return '<span class="mk-chg ' + (up ? 'up' : 'dn') + '">' + (up ? '▲' : '▼') + ' ' + (up ? '+' : '') + c.toFixed(2) + '%</span>';
}

/* ═══════════════════════════════════════════
   RENDER CRYPTO TABLE (30 rows)
═══════════════════════════════════════════ */
function renderCrypto() {
  var tb = document.getElementById('crypto-tbody');
  if (!tb) return;
  tb.innerHTML = '';
  CRYPTO.forEach(function(d) {
    var up = d.chg >= 0;
    var color = up ? '#00e676' : '#ff4757';
    var id = 'c' + d.rank;
    var tr = document.createElement('tr');
    tr.innerHTML =
      '<td style="color:#5a6380;font-size:.78rem;font-weight:700;width:28px">#' + d.rank + '</td>' +
      '<td>' +
        '<div class="mk-coin-cell">' +
          '<div class="mk-coin-logo" style="background:' + d.bg + ';color:#fff">' + d.logo + '</div>' +
          '<div><span class="mk-coin-name">' + d.name + '</span><span class="mk-coin-sym">' + d.sym + '</span></div>' +
        '</div>' +
      '</td>' +
      '<td class="mk-price-val" id="price-' + id + '">' + fmtPrice(d.price) + '</td>' +
      '<td id="chg-' + id + '">' + fmtChg(d.chg) + '</td>' +
      '<td><canvas class="mk-spark" id="spk-' + id + '"></canvas></td>';
    tb.appendChild(tr);
    drawSpark(document.getElementById('spk-' + id), d.history, color);
  });
}

/* ═══════════════════════════════════════════
   BINANCE WEBSOCKET — all 30 pairs real-time
═══════════════════════════════════════════ */
function initBinanceWS() {
  var streams = CRYPTO.map(function(c) { return c.pair.toLowerCase() + '@miniTicker'; }).join('/');
  var ws, retryDelay = 3000;

  function connect() {
    try {
      ws = new WebSocket('wss://stream.binance.com:9443/stream?streams=' + streams);
      ws.onopen = function() { retryDelay = 3000; };

      ws.onmessage = function(e) {
        try {
          var msg = JSON.parse(e.data);
          var t = msg.data;
          if (!t || !t.s) return;
          var coin = pairMap[t.s];
          if (!coin) return;
          var price = parseFloat(t.c);
          var open  = parseFloat(t.o);
          coin.price = price;
          coin.chg   = +((price - open) / open * 100).toFixed(2);
          var id = 'c' + coin.rank;
          var pEl = document.getElementById('price-' + id);
          var cEl = document.getElementById('chg-' + id);
          if (pEl) pEl.textContent = fmtPrice(coin.price);
          if (cEl) cEl.innerHTML = fmtChg(coin.chg);
          coin.history.push(coin.price);
          coin.history.shift();
          drawSpark(document.getElementById('spk-' + id), coin.history, coin.chg >= 0 ? '#00e676' : '#ff4757');
        } catch(_) {}
      };

      ws.onclose = function() {
        retryDelay = Math.min(retryDelay * 1.5, 30000);
        setTimeout(connect, retryDelay);
      };
      ws.onerror = function() { ws.close(); };
    } catch(_) { setTimeout(connect, retryDelay); }
  }
  connect();
}

/* ═══════════════════════════════════════════
   CLOCK (UTC)
═══════════════════════════════════════════ */
function updateClock() {
  var now = new Date();
  var h = now.getUTCHours(), m = now.getUTCMinutes();
  var pad = function(n) { return String(n).padStart(2, '0'); };
  var el = document.getElementById('mk-clock');
  if (el) el.textContent = pad(h) + ':' + pad(m) + ' UTC';
}

/* ═══════════════════════════════════════════
   BOOT
═══════════════════════════════════════════ */
document.addEventListener('DOMContentLoaded', function() {
  updateClock();
  renderCrypto();
  initBinanceWS();
  setInterval(updateClock, 10000);
  window.addEventListener('resize', renderCrypto);
});
</script>

