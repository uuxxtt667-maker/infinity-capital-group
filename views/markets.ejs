<style>
.mk-ticker { background:#050a14; border-bottom:1px solid #111827; overflow:hidden; white-space:nowrap; padding:.5rem 0; position:relative; }
.mk-ticker::before,.mk-ticker::after { content:''; position:absolute; top:0; width:60px; height:100%; z-index:2; pointer-events:none; }
.mk-ticker::before { left:0;  background:linear-gradient(to right, #050a14, transparent); }
.mk-ticker::after  { right:0; background:linear-gradient(to left,  #050a14, transparent); }
.mk-ticker-track { display:inline-flex; animation:mkTickAnim 40s linear infinite; }
.mk-ticker-track:hover { animation-play-state:paused; }
@keyframes mkTickAnim { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
.mk-tick-item { display:inline-flex; align-items:center; gap:.4rem; padding:0 1.2rem; border-right:1px solid rgba(17,24,39,.9); font-size:.74rem; white-space:nowrap; }
.mk-tick-sym  { font-weight:800; color:#e2e8f0; font-size:.72rem; }
.mk-tick-px   { font-weight:700; color:#f1f5f9; font-variant-numeric:tabular-nums; }
.mk-tick-chg.up { color:#00e676; font-weight:700; }
.mk-tick-chg.dn { color:#ff4757; font-weight:700; }
</style>
<div class="mk-ticker">
  <div class="mk-ticker-track" id="mk-tick-track"></div>
</div>
<script>
(function(){
  var MC=[
    {sym:'BTC/USDT',pair:'BTCUSDT',price:77525,chg:2.41},
    {sym:'ETH/USDT',pair:'ETHUSDT',price:2116,chg:1.82},
    {sym:'BNB/USDT',pair:'BNBUSDT',price:661,chg:0.93},
    {sym:'SOL/USDT',pair:'SOLUSDT',price:86,chg:3.14},
    {sym:'XRP/USDT',pair:'XRPUSDT',price:1.36,chg:-0.67},
    {sym:'DOGE/USDT',pair:'DOGEUSDT',price:0.1029,chg:-1.04},
    {sym:'ADA/USDT',pair:'ADAUSDT',price:0.2458,chg:1.22},
    {sym:'TRX/USDT',pair:'TRXUSDT',price:0.3666,chg:0.55},
    {sym:'AVAX/USDT',pair:'AVAXUSDT',price:9.42,chg:-1.23},
    {sym:'TON/USDT',pair:'TONUSDT',price:1.81,chg:2.10}
  ];
  var mcMap={};
  MC.forEach(function(c){ mcMap[c.pair]=c; });

  function mFmt(p){
    if(p>=10000) return '$'+p.toLocaleString('en-US',{maximumFractionDigits:0});
    if(p>=100)   return '$'+p.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
    if(p>=1)     return '$'+p.toFixed(3);
    if(p>=0.01)  return '$'+p.toFixed(4);
    return '$'+p.toFixed(6);
  }
  function mkBuild(){
    var h='';
    function row(c){
      var up=c.chg>=0;
      return '<span class="mk-tick-item">'+
        '<span class="mk-tick-sym">'+c.sym+'</span>'+
        '<span class="mk-tick-px" id="mktk-'+c.pair+'">'+mFmt(c.price)+'</span>'+
        '<span class="mk-tick-chg '+(up?'up':'dn')+'" id="mktkc-'+c.pair+'">'+(up?'▲':'▼')+Math.abs(c.chg).toFixed(2)+'%</span>'+
      '</span>';
    }
    MC.forEach(function(c){ h+=row(c); });
    MC.forEach(function(c){ h+=row(c); });
    return h;
  }
  document.getElementById('mk-tick-track').innerHTML=mkBuild();

  var mkStreams=MC.map(function(c){ return c.pair.toLowerCase()+'@miniTicker'; }).join('/');
  var mkRetry=1000;
  function mkWS(){
    try{
      var ws=new WebSocket('wss://stream.binance.com:9443/stream?streams='+mkStreams);
      ws.onmessage=function(e){
        try{
          var msg=JSON.parse(e.data),d=msg.data||msg;
          var price=parseFloat(d.c),open=parseFloat(d.o),chg=(price-open)/open*100;
          var sym=(d.s||'').toUpperCase(),c=mcMap[sym]; if(!c) return;
          c.price=price; c.chg=chg;
          var str=(chg>=0?'▲':'▼')+Math.abs(chg).toFixed(2)+'%';
          var cls='mk-tick-chg '+(chg>=0?'up':'dn');
          document.querySelectorAll('[id="mktk-'+sym+'"]').forEach(function(el){ el.textContent=mFmt(price); });
          document.querySelectorAll('[id="mktkc-'+sym+'"]').forEach(function(el){ el.textContent=str; el.className=cls; });
          mkRetry=1000;
        }catch(_){}
      };
      ws.onclose=function(){ mkRetry=Math.min(mkRetry*1.5,30000); setTimeout(mkWS,mkRetry); };
      ws.onerror=function(){ ws.close(); };
    }catch(_){}
  }
  mkWS();
})();
</script>

