<% pageTitle = 'Reset Password' %>
<%- include('partials/head') %>
<%- include('partials/nav') %>

<style>
.rp-outer {
  min-height: calc(100vh - 68px);
  display: flex; align-items: center; justify-content: center;
  padding: 2rem 1rem;
  position: relative; z-index: 1;
}
.rp-card {
  width: 100%; max-width: 480px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 2.75rem 2.5rem 2.25rem;
  position: relative; z-index: 1;
}
.rp-icon {
  width: 64px; height: 64px; border-radius: 50%;
  background: linear-gradient(135deg, rgba(245,166,35,.18), rgba(245,166,35,.05));
  border: 2px solid rgba(245,166,35,.35);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.6rem; color: var(--gold);
  margin: 0 auto 1.4rem;
}
.rp-title { font-size: 1.35rem; font-weight: 800; color: var(--text); text-align: center; margin-bottom: .4rem; }
.rp-sub   { font-size: .84rem; color: var(--text3); text-align: center; margin-bottom: 2rem; line-height: 1.55; }
.rp-label { font-size: .75rem; font-weight: 700; color: var(--text2); margin-bottom: .45rem; display: block; }

/* OTP row */
.rp-otp-inputs { display: flex; gap: .55rem; justify-content: center; margin-bottom: 1.5rem; }
.rp-otp-digit {
  width: 52px; height: 60px;
  text-align: center; font-size: 1.6rem; font-weight: 800;
  border: 2px solid var(--border); border-radius: 12px;
  background: var(--bg2); color: var(--text);
  outline: none; transition: border-color .2s, box-shadow .2s;
  caret-color: transparent;
}
.rp-otp-digit:focus { border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-light); }
.rp-otp-digit.filled { border-color: var(--gold); }

/* Password fields */
.rp-wrap  { position: relative; margin-bottom: 1rem; }
.rp-icon2 { position: absolute; left: .9rem; top: 50%; transform: translateY(-50%); color: var(--text3); font-size: .85rem; }
.rp-input {
  width: 100%; padding: .72rem 2.6rem .72rem 2.4rem;
  border: 1.5px solid var(--border); border-radius: 10px;
  background: var(--bg2); color: var(--text); font-size: .9rem;
  outline: none; transition: border-color .2s, box-shadow .2s;
  box-sizing: border-box;
}
.rp-input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-light); }
.rp-input::placeholder { color: var(--text3); }
.rp-eye { position: absolute; right: .85rem; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text3); cursor: pointer; padding: .2rem; font-size: .85rem; }

.rp-divider { display: flex; align-items: center; gap: .75rem; color: var(--text3); font-size: .75rem; margin: 1.1rem 0; }
.rp-divider::before, .rp-divider::after { content:''; flex:1; height:1px; background:var(--border); }

.rp-btn {
  width: 100%; padding: .82rem;
  border: none; border-radius: 11px;
  background: linear-gradient(135deg, var(--gold), var(--gold2));
  color: #000; font-size: .95rem; font-weight: 800;
  cursor: pointer; transition: transform .15s, box-shadow .15s;
  margin-bottom: 1rem;
}
.rp-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px var(--gold-light); }

.rp-resend { text-align: center; font-size: .82rem; color: var(--text3); }
.rp-resend button {
  background: none; border: none; color: var(--gold); font-weight: 700;
  cursor: pointer; font-size: .82rem; padding: 0;
  text-decoration: underline; text-decoration-style: dotted;
}
.rp-timer { color: var(--text3); font-size: .78rem; margin-top: .3rem; text-align: center; }
.rp-hint  { font-size: .75rem; color: var(--text3); margin-bottom: 1rem; }
</style>

<div class="rp-outer">
  <div class="rp-card">
    <div class="rp-icon"><i class="fas fa-lock-open"></i></div>
    <div class="rp-title">Reset Your Password</div>
    <div class="rp-sub">
      Enter the 6-digit code we sent to<br>
      <strong style="color:var(--gold)"><%= email %></strong>
    </div>

    <form method="POST" action="/reset-password" id="rpForm">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <input type="hidden" name="otp" id="rpOtpHidden">

      <!-- OTP digits -->
      <label class="rp-label" style="text-align:center;display:block">Verification Code</label>
      <div class="rp-otp-inputs" id="rpOtpInputs">
        <input class="rp-otp-digit" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="one-time-code">
        <input class="rp-otp-digit" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
        <input class="rp-otp-digit" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
        <input class="rp-otp-digit" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
        <input class="rp-otp-digit" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
        <input class="rp-otp-digit" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
      </div>

      <div class="rp-divider">then create a new password</div>

      <label class="rp-label" for="rp-pwd">New Password</label>
      <div class="rp-wrap">
        <i class="fas fa-lock rp-icon2"></i>
        <input type="password" id="rp-pwd" name="password" class="rp-input"
          placeholder="Min. 8 characters" required autocomplete="new-password">
        <button type="button" class="rp-eye" onclick="toggleEye('rp-pwd','eye1')"><i class="fas fa-eye" id="eye1"></i></button>
      </div>
      <p class="rp-hint"><i class="fas fa-info-circle" style="color:var(--gold)"></i> At least 8 characters.</p>

      <label class="rp-label" for="rp-pwd2">Confirm New Password</label>
      <div class="rp-wrap">
        <i class="fas fa-lock rp-icon2"></i>
        <input type="password" id="rp-pwd2" name="confirm_password" class="rp-input"
          placeholder="Repeat your password" required autocomplete="new-password">
        <button type="button" class="rp-eye" onclick="toggleEye('rp-pwd2','eye2')"><i class="fas fa-eye" id="eye2"></i></button>
      </div>

      <button type="submit" class="rp-btn" id="rpSubmit" disabled>
        <i class="fas fa-shield-alt" style="margin-right:.4rem"></i>Update Password
      </button>
    </form>

    <div class="rp-resend">
      Didn't receive a code?
      <form method="POST" action="/reset-password/resend" style="display:inline">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <button type="submit">Resend code</button>
      </form>
    </div>
    <div class="rp-timer" id="rpTimer"></div>
  </div>
</div>

<script>
(function(){
  var digits  = Array.from(document.querySelectorAll('.rp-otp-digit'));
  var hidden  = document.getElementById('rpOtpHidden');
  var submitBtn = document.getElementById('rpSubmit');
  var pwd1    = document.getElementById('rp-pwd');
  var pwd2    = document.getElementById('rp-pwd2');

  function getCode(){ return digits.map(function(d){ return d.value; }).join(''); }
  function canSubmit(){
    return getCode().length===6 && pwd1.value.length>=8 && pwd1.value===pwd2.value;
  }
  function refresh(){
    var c = getCode();
    hidden.value = c;
    digits.forEach(function(d){ d.classList.toggle('filled', d.value!==''); });
    submitBtn.disabled = !canSubmit();
  }

  digits.forEach(function(d, i){
    d.addEventListener('input', function(){
      if(d.value.length > 1){
        var pasted = d.value.replace(/\D/g,'').slice(0,6);
        pasted.split('').forEach(function(ch,j){ if(digits[j]) digits[j].value=ch; });
        digits[Math.min(pasted.length,5)].focus();
        refresh(); return;
      }
      d.value = d.value.replace(/\D/,'');
      if(d.value && i<5) digits[i+1].focus();
      refresh();
    });
    d.addEventListener('keydown', function(e){
      if(e.key==='Backspace' && !d.value && i>0){ digits[i-1].focus(); digits[i-1].value=''; refresh(); }
    });
    d.addEventListener('paste', function(e){
      e.preventDefault();
      var text=(e.clipboardData||window.clipboardData).getData('text').replace(/\D/g,'').slice(0,6);
      text.split('').forEach(function(ch,j){ if(digits[j]) digits[j].value=ch; });
      digits[Math.min(text.length,5)].focus();
      refresh();
    });
  });
  pwd1.addEventListener('input', refresh);
  pwd2.addEventListener('input', refresh);

  // Timer
  var expiry = Date.now() + 15*60*1000;
  var timerEl = document.getElementById('rpTimer');
  function tick(){
    var left = Math.max(0, expiry-Date.now());
    var m=Math.floor(left/60000), s=Math.floor((left%60000)/1000);
    timerEl.textContent = 'Code expires in '+m+':'+(s<10?'0':'')+s;
    if(left>0) setTimeout(tick,1000);
    else timerEl.textContent='Code expired — click "Resend code" to get a new one.';
  }
  tick();
  if(digits[0]) digits[0].focus();
})();

function toggleEye(inputId, eyeId){
  var inp = document.getElementById(inputId);
  var eye = document.getElementById(eyeId);
  if(inp.type==='password'){ inp.type='text'; eye.className='fas fa-eye-slash'; }
  else { inp.type='password'; eye.className='fas fa-eye'; }
}
</script>

<%- include('partials/footer') %>
