# Dependencies
node_modules/

# Database files (user data — do not commit)
data/*.db

# Live settings/customize is written by the running app — NOT tracked,
# so admin changes on the server never conflict with git deploys.
# A template (data/settings.example.json) IS committed; the app copies it
# to data/settings.json on first run if the live file is missing.
data/settings.json

# Logs
*.log
logs/

# Environment / secrets
.env
.env.*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Cloudflared binary
cloudflared
data/users.db~
*.db~
